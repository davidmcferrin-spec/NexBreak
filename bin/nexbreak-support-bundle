#!/usr/bin/env python3
"""
nexbreak-support-bundle — build a redacted zip for bake-in / remote debug.

Runs as root via nexbreak-ops-support-bundle.sh (sudoers allowlist).
Stdout: absolute path to the zip (single line). Progress on stderr.

stdlib only — no pip.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import socket
import sqlite3
import subprocess
import sys
import time
import zipfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Optional

ALLOWED_HOURS = frozenset({1, 6, 12, 24, 48, 72})
UNITS = (
    "nexbreak-controller",
    "nexbreak-verify",
    "nexbreak-mediamtx",
    *[f"nexbreak-proc@{i}" for i in range(1, 5)],
    *[f"nexbreak-egress@{i}" for i in range(1, 5)],
)

# Soft caps so a noisy journal cannot fill the disk.
MAX_JOURNAL_BYTES_PER_UNIT = 8 * 1024 * 1024  # 8 MiB
MAX_ZIP_BYTES = 100 * 1024 * 1024  # 100 MiB warn threshold
BUNDLE_RETENTION_HOURS = 24

# URL userinfo + common secret field names
_RE_URL_CREDS = re.compile(
    r"(?i)\b((?:rtsp|rtsps|srt|http|https|ftp)://)([^/\s:@]+):([^/\s@]+)@"
)
_RE_KEY_VALUE_SECRET = re.compile(
    r"(?i)\b(password|passwd|passphrase|secret|api[_-]?key|token|authorization)"
    r"(\s*[=:]\s*)([^\s,;\"']+)"
)
_SECRET_KEYS = frozenset(
    {
        "api_key",
        "key_hash",
        "password",
        "passwd",
        "passphrase",
        "srt_passphrase",
        "secret",
        "token",
        "authorization",
        "auth",
    }
)


def log(msg: str) -> None:
    print(msg, file=sys.stderr, flush=True)


def data_dir() -> Path:
    return Path(os.environ.get("NEXBREAK_DATA", "/var/lib/nexbreak"))


def run_dir() -> Path:
    return Path(os.environ.get("NEXBREAK_RUN_DIR", "/run/nexbreak"))


def db_path() -> Path:
    env = os.environ.get("NEXBREAK_DB")
    if env:
        return Path(env)
    return data_dir() / "nexbreak.sqlite"


def prefix_dir() -> Path:
    return Path(os.environ.get("NEXBREAK_PREFIX", "/opt/nexbreak"))


def redact_text(text: str) -> str:
    if not text:
        return text
    out = _RE_URL_CREDS.sub(r"\1***:***@", text)
    out = _RE_KEY_VALUE_SECRET.sub(r"\1\2***", out)
    return out


def redact_obj(obj: Any) -> Any:
    if isinstance(obj, dict):
        out: dict[str, Any] = {}
        for k, v in obj.items():
            lk = str(k).lower()
            if lk in _SECRET_KEYS or lk.endswith("_password") or lk.endswith("_passphrase"):
                out[k] = "***" if v not in (None, "") else v
            elif isinstance(v, str) and (
                "://" in v or lk.endswith("_url") or "url" in lk or "key" in lk
            ):
                out[k] = redact_text(v)
            else:
                out[k] = redact_obj(v)
        return out
    if isinstance(obj, list):
        return [redact_obj(x) for x in obj]
    if isinstance(obj, str):
        return redact_text(obj)
    return obj


def run_cmd(
    argv: list[str],
    *,
    timeout: float = 30.0,
    text: bool = True,
) -> tuple[int, str, str]:
    try:
        proc = subprocess.run(
            argv,
            capture_output=True,
            text=text,
            timeout=timeout,
            check=False,
        )
        out = proc.stdout if text else ""
        err = proc.stderr if text else ""
        if text:
            out = out or ""
            err = err or ""
        return int(proc.returncode), out, err
    except FileNotFoundError:
        return 127, "", f"not found: {argv[0]}"
    except subprocess.TimeoutExpired:
        return 124, "", f"timeout after {timeout}s: {' '.join(argv)}"


def write_text(path: Path, body: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(redact_text(body), encoding="utf-8", errors="replace")


def write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        json.dumps(redact_obj(data), indent=2, default=str) + "\n",
        encoding="utf-8",
    )


def which_version(cmd: str, args: list[str]) -> str:
    code, out, err = run_cmd([cmd, *args], timeout=8.0)
    blob = (out or err or "").strip()
    if code == 127:
        return f"{cmd}: not installed\n"
    return (blob or f"{cmd}: exit {code}") + "\n"


def collect_host(dest: Path) -> None:
    dest.mkdir(parents=True, exist_ok=True)
    write_text(dest / "uname.txt", run_cmd(["uname", "-a"])[1])
    write_text(dest / "uptime.txt", run_cmd(["uptime"])[1])
    write_text(dest / "free.txt", run_cmd(["free", "-h"])[1])
    write_text(dest / "df.txt", run_cmd(["df", "-h"])[1])
    write_text(dest / "ip.txt", run_cmd(["ip", "-br", "a"])[1])
    write_text(dest / "lsblk.txt", run_cmd(["lsblk", "-o", "NAME,SIZE,TYPE,MOUNTPOINT"])[1])
    write_text(dest / "timedatectl.txt", run_cmd(["timedatectl"])[1])
    # Optional host snapshot via installed module
    try:
        sys.path.insert(0, str(prefix_dir() / "bin"))
        from nexbreak_host import host_snapshot  # type: ignore

        write_json(dest / "host_snapshot.json", host_snapshot())
    except Exception as exc:  # noqa: BLE001
        write_text(dest / "host_snapshot.error.txt", f"{exc}\n")
    code, out, err = run_cmd(["dmesg", "-T", "--level=err,warn"], timeout=10.0)
    if code == 0 and out:
        lines = out.splitlines()
        write_text(dest / "dmesg-warn-err-tail.txt", "\n".join(lines[-200:]) + "\n")
    elif err:
        write_text(dest / "dmesg.error.txt", err)


def collect_versions(dest: Path) -> None:
    dest.mkdir(parents=True, exist_ok=True)
    write_text(dest / "ffmpeg.txt", which_version("ffmpeg", ["-version"]))
    write_text(dest / "ffprobe.txt", which_version("ffprobe", ["-version"]))
    write_text(dest / "tsp.txt", which_version("tsp", ["--version"]))
    write_text(dest / "python3.txt", which_version("python3", ["--version"]))
    write_text(dest / "php.txt", which_version("php", ["-v"]))
    write_text(dest / "apache2ctl.txt", which_version("apache2ctl", ["-v"]))
    mtx = shutil.which("mediamtx") or "/usr/local/bin/mediamtx"
    if Path(mtx).is_file():
        write_text(dest / "mediamtx.txt", which_version(mtx, ["--version"]))
    else:
        write_text(dest / "mediamtx.txt", "mediamtx: not found\n")
    code, out, _ = run_cmd(
        ["dpkg-query", "-W", "-f=${Package}\\t${Version}\\n"],
        timeout=15.0,
    )
    if code == 0 and out:
        keep = []
        for line in out.splitlines():
            low = line.lower()
            if any(
                x in low
                for x in (
                    "tsduck",
                    "ffmpeg",
                    "libsrt",
                    "vosk",
                    "apache2",
                    "php",
                    "gstreamer",
                )
            ):
                keep.append(line)
        write_text(dest / "dpkg-relevant.txt", "\n".join(keep) + ("\n" if keep else ""))
    # NexBreak install marker
    ver_bits: dict[str, Any] = {"prefix": str(prefix_dir())}
    git_dir = prefix_dir() / ".git"
    if git_dir.is_dir():
        c, o, _ = run_cmd(
            ["git", "-C", str(prefix_dir()), "rev-parse", "--short", "HEAD"],
            timeout=5.0,
        )
        if c == 0:
            ver_bits["git_head"] = o.strip()
        c, o, _ = run_cmd(
            ["git", "-C", str(prefix_dir()), "describe", "--tags", "--always", "--dirty"],
            timeout=5.0,
        )
        if c == 0:
            ver_bits["git_describe"] = o.strip()
    write_json(dest / "nexbreak.json", ver_bits)


def collect_systemd(dest: Path) -> None:
    dest.mkdir(parents=True, exist_ok=True)
    # Batch status
    lines: list[str] = []
    for unit in UNITS:
        c1, a, _ = run_cmd(["systemctl", "is-active", unit], timeout=5.0)
        c2, e, _ = run_cmd(["systemctl", "is-enabled", unit], timeout=5.0)
        lines.append(f"{unit}\t{(a or 'unknown').strip()}\t{(e or 'unknown').strip()}")
    write_text(dest / "is-active-enabled.txt", "\n".join(lines) + "\n")

    chunks: list[str] = []
    for unit in UNITS:
        c, out, err = run_cmd(
            ["systemctl", "status", unit, "--no-pager", "-l"],
            timeout=10.0,
        )
        chunks.append(f"===== {unit} (exit {c}) =====\n{out or err}\n")
    write_text(dest / "status.txt", "".join(chunks))

    c, out, err = run_cmd(
        ["systemctl", "list-units", "nexbreak*", "--all", "--no-pager"],
        timeout=10.0,
    )
    write_text(dest / "list-units.txt", out or err)

    unit_files = dest / "unit-files"
    unit_files.mkdir(parents=True, exist_ok=True)
    for unit in UNITS:
        c, out, err = run_cmd(
            ["systemctl", "cat", unit],
            timeout=8.0,
        )
        safe = unit.replace("@", "_at_")
        write_text(unit_files / f"{safe}.service.txt", out or err or "(empty)\n")


def collect_journals(dest: Path, hours: int) -> list[str]:
    dest.mkdir(parents=True, exist_ok=True)
    notes: list[str] = []
    since = f"{hours} hours ago"
    for unit in UNITS:
        log(f"journal {unit} --since '{since}'")
        c, out, err = run_cmd(
            [
                "journalctl",
                "-u",
                unit,
                "--since",
                since,
                "--no-pager",
                "-o",
                "short-iso",
            ],
            timeout=90.0,
        )
        body = out if c == 0 else (err or out or f"journalctl exit {c}\n")
        raw = body.encode("utf-8", errors="replace")
        if len(raw) > MAX_JOURNAL_BYTES_PER_UNIT:
            raw = raw[-MAX_JOURNAL_BYTES_PER_UNIT:]
            # Align to next newline
            nl = raw.find(b"\n")
            if nl >= 0:
                raw = raw[nl + 1 :]
            notes.append(
                f"{unit}: truncated to last {MAX_JOURNAL_BYTES_PER_UNIT} bytes"
            )
            body = (
                f"[nexbreak-support-bundle: truncated to last "
                f"{MAX_JOURNAL_BYTES_PER_UNIT} bytes]\n"
                + raw.decode("utf-8", errors="replace")
            )
        safe = unit.replace("@", "_at_")
        write_text(dest / f"{safe}.log", body)
        if c != 0:
            notes.append(f"{unit}: journalctl exit {c}")
    return notes


def sqlite_rows(conn: sqlite3.Connection, sql: str, params: tuple = ()) -> list[dict]:
    conn.row_factory = sqlite3.Row
    cur = conn.execute(sql, params)
    return [dict(r) for r in cur.fetchall()]


def collect_config(dest: Path, hours: int) -> list[str]:
    dest.mkdir(parents=True, exist_ok=True)
    notes: list[str] = []
    db = db_path()
    if not db.is_file():
        write_text(dest / "db.error.txt", f"DB missing: {db}\n")
        notes.append(f"DB missing: {db}")
        return notes

    try:
        conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True, timeout=10)
    except sqlite3.Error as exc:
        write_text(dest / "db.error.txt", f"{exc}\n")
        notes.append(str(exc))
        return notes

    try:
        write_json(dest / "processing_channels.json", sqlite_rows(conn, "SELECT * FROM processing_channels ORDER BY id"))
        write_json(dest / "egress_channels.json", sqlite_rows(conn, "SELECT * FROM egress_channels ORDER BY id"))
        write_json(dest / "routing_assignments.json", sqlite_rows(conn, "SELECT * FROM routing_assignments ORDER BY id"))
        try:
            write_json(
                dest / "splice_presets.json",
                sqlite_rows(conn, "SELECT * FROM splice_presets ORDER BY sort_order, id"),
            )
        except sqlite3.Error:
            notes.append("splice_presets table missing")

        # Credentials: metadata only — never api_key / key_hash
        try:
            creds = sqlite_rows(
                conn,
                """
                SELECT id, label, created_at, last_used_at, revoked,
                       CASE WHEN api_key IS NOT NULL AND length(api_key) > 0
                            THEN length(api_key) ELSE NULL END AS api_key_len,
                       CASE WHEN key_hash IS NOT NULL AND length(key_hash) > 0
                            THEN 1 ELSE 0 END AS has_key_hash
                FROM control_credentials
                ORDER BY id
                """,
            )
            write_json(dest / "control_credentials_meta.json", creds)
        except sqlite3.Error as exc:
            notes.append(f"credentials: {exc}")

        # Caption libs: counts + sample lengths, not full blacklist text if huge
        try:
            lex = sqlite_rows(conn, "SELECT COUNT(*) AS n FROM caption_lexicon")
            bl = sqlite_rows(conn, "SELECT COUNT(*) AS n FROM caption_blacklist")
            write_json(
                dest / "caption_libraries.json",
                {
                    "lexicon_count": lex[0]["n"] if lex else 0,
                    "blacklist_count": bl[0]["n"] if bl else 0,
                    "note": "word lists omitted from support bundle (compliance)",
                },
            )
        except sqlite3.Error:
            pass

        # Audit for window
        try:
            audit = sqlite_rows(
                conn,
                """
                SELECT id, processing_channel_id, egress_channel_id, event_type,
                       splice_type, triggered_by_credential_id, source_ip,
                       result, detail, occurred_at
                FROM audit_events
                WHERE datetime(occurred_at) >= datetime('now', ?)
                ORDER BY id DESC
                LIMIT 5000
                """,
                (f"-{int(hours)} hours",),
            )
            # Drop hex payloads from export name — column omitted above
            write_json(dest / "audit_events.json", audit)
        except sqlite3.Error as exc:
            notes.append(f"audit: {exc}")

        # Schema
        schema_lines: list[str] = []
        for row in conn.execute(
            "SELECT sql FROM sqlite_master WHERE sql IS NOT NULL ORDER BY type, name"
        ):
            schema_lines.append(row[0] + ";")
        write_text(dest / "schema.sql", "\n\n".join(schema_lines) + "\n")

        # Host metric history (CPU/mem/swap/GPU) for the same window
        try:
            since = time.time() - float(hours) * 3600.0
            samples = sqlite_rows(
                conn,
                """
                SELECT sampled_at, cpu_percent, mem_percent, swap_percent,
                       gpu_percent, load_1m, uptime_seconds
                FROM host_metric_samples
                WHERE sampled_at >= ?
                ORDER BY sampled_at ASC
                LIMIT 30000
                """,
                (since,),
            )
            write_json(dest / "host_metric_samples.json", samples)
            write_text(
                dest / "host_metric_samples.csv",
                "sampled_at,cpu_percent,mem_percent,swap_percent,gpu_percent,load_1m,uptime_seconds\n"
                + "\n".join(
                    ",".join(
                        str(r.get(k) if r.get(k) is not None else "")
                        for k in (
                            "sampled_at",
                            "cpu_percent",
                            "mem_percent",
                            "swap_percent",
                            "gpu_percent",
                            "load_1m",
                            "uptime_seconds",
                        )
                    )
                    for r in samples
                )
                + ("\n" if samples else ""),
            )
        except sqlite3.Error as exc:
            notes.append(f"host_metric_samples: {exc}")
    finally:
        conn.close()

    # Apache / MediaMTX configs (redacted on write)
    candidates = [
        (Path("/etc/apache2/sites-available/nexbreak.conf"), "apache-nexbreak.conf"),
        (Path("/etc/mediamtx.yml"), "mediamtx.yml"),
        (prefix_dir() / "config" / "mediamtx.yml", "mediamtx.yml.from-tree"),
    ]
    for src, name in candidates:
        if src.is_file():
            try:
                write_text(dest / name, src.read_text(encoding="utf-8", errors="replace"))
            except OSError as exc:
                notes.append(f"{name}: {exc}")

    return notes


def collect_state(dest: Path) -> list[str]:
    dest.mkdir(parents=True, exist_ok=True)
    notes: list[str] = []
    rd = run_dir()
    if not rd.is_dir():
        write_text(dest / "run-dir.missing.txt", f"missing {rd}\n")
        notes.append(f"run dir missing: {rd}")
        return notes

    # Copy small JSON / text state; skip sockets and large binaries
    for root, dirs, files in os.walk(rd):
        # skip deep noise
        dirs[:] = [d for d in dirs if d not in (".",)]
        rel_root = Path(root).relative_to(rd)
        for name in files:
            src = Path(root) / name
            if src.is_symlink() or not src.is_file():
                continue
            # sockets appear as files sometimes — skip non-regular
            try:
                st = src.stat()
            except OSError:
                continue
            if st.st_size > 2 * 1024 * 1024:
                notes.append(f"skipped large state file: {src} ({st.st_size} bytes)")
                continue
            if name.endswith(".sock") or src.suffix == ".sock":
                continue
            rel = rel_root / name if str(rel_root) != "." else Path(name)
            dst = dest / "run-nexbreak" / rel
            try:
                raw = src.read_bytes()
                # Prefer text/json
                try:
                    text = raw.decode("utf-8")
                    if name.endswith(".json") or text.lstrip().startswith(("{", "[")):
                        try:
                            write_json(dst, json.loads(text))
                        except json.JSONDecodeError:
                            write_text(dst, text)
                    else:
                        write_text(dst, text)
                except UnicodeDecodeError:
                    notes.append(f"skipped binary state: {src}")
            except OSError as exc:
                notes.append(f"{src}: {exc}")

    # Persist SCTE watch dir summary (under data, not run)
    scte = data_dir() / "scte"
    if scte.is_dir():
        summary: list[dict[str, Any]] = []
        for p in sorted(scte.iterdir()):
            try:
                st = p.stat()
                summary.append(
                    {
                        "name": p.name,
                        "is_dir": p.is_dir(),
                        "size": st.st_size if p.is_file() else None,
                        "mtime": st.st_mtime,
                    }
                )
            except OSError:
                continue
        write_json(dest / "scte_dir_listing.json", summary)

    return notes


def prune_old_bundles(support_dir: Path) -> None:
    if not support_dir.is_dir():
        return
    cutoff = time.time() - BUNDLE_RETENTION_HOURS * 3600
    for p in support_dir.glob("nexbreak-support-*.zip"):
        try:
            if p.stat().st_mtime < cutoff:
                p.unlink()
                log(f"pruned old bundle {p.name}")
        except OSError:
            pass


def zip_tree(src_dir: Path, zip_path: Path) -> int:
    count = 0
    with zipfile.ZipFile(
        zip_path,
        "w",
        compression=zipfile.ZIP_DEFLATED,
        compresslevel=6,
    ) as zf:
        for root, _dirs, files in os.walk(src_dir):
            for name in files:
                full = Path(root) / name
                arc = full.relative_to(src_dir).as_posix()
                zf.write(full, arcname=arc)
                count += 1
    return count


def build_bundle(
    *,
    hours: int,
    requestor_ip: str = "",
    out_dir: Optional[Path] = None,
) -> Path:
    if hours not in ALLOWED_HOURS:
        raise SystemExit(f"hours must be one of {sorted(ALLOWED_HOURS)}")

    support = out_dir or (data_dir() / "support")
    support.mkdir(parents=True, exist_ok=True)
    try:
        os.chmod(support, 0o750)
    except OSError:
        pass
    try:
        import grp

        gid = grp.getgrnam("www-data").gr_gid
        os.chown(support, 0, gid)
    except (OSError, KeyError, ImportError):
        pass
    prune_old_bundles(support)

    host = socket.gethostname() or "host"
    stamp = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
    base_name = f"nexbreak-support-{stamp}-{host}-{hours}h"
    work = support / f".work-{base_name}"
    if work.exists():
        shutil.rmtree(work, ignore_errors=True)
    work.mkdir(parents=True)

    redactions = [
        "URL userinfo (user:pass@) → ***:***@",
        "password/passphrase/api_key/token field values → ***",
        "control_credentials api_key and key_hash omitted (meta only)",
        "caption lexicon/blacklist word lists omitted",
        "audit splice_hex_payload omitted",
        "HLS segments and raw media not included",
        f"journals truncated per unit at {MAX_JOURNAL_BYTES_PER_UNIT} bytes if larger",
    ]
    notes: list[str] = []

    try:
        log("collecting host…")
        collect_host(work / "host")
        log("collecting versions…")
        collect_versions(work / "versions")
        log("collecting systemd…")
        collect_systemd(work / "systemd")
        log("collecting journals…")
        notes.extend(collect_journals(work / "journal", hours))
        log("collecting config…")
        notes.extend(collect_config(work / "config", hours))
        log("collecting runtime state…")
        notes.extend(collect_state(work / "state"))

        write_text(work / "REDACTIONS.txt", "\n".join(f"- {x}" for x in redactions) + "\n")
        if notes:
            write_text(work / "NOTES.txt", "\n".join(f"- {x}" for x in notes) + "\n")

        manifest = {
            "product": "NexBreak",
            "bundle_format": 1,
            "created_at_utc": datetime.now(timezone.utc).isoformat(),
            "hostname": host,
            "hours": hours,
            "requestor_ip": requestor_ip or None,
            "db_path": str(db_path()),
            "data_dir": str(data_dir()),
            "run_dir": str(run_dir()),
            "prefix": str(prefix_dir()),
            "units": list(UNITS),
            "notes": notes,
            "redactions": redactions,
        }
        write_json(work / "MANIFEST.json", manifest)

        zip_path = support / f"{base_name}.zip"
        log(f"zipping → {zip_path}")
        nfiles = zip_tree(work, zip_path)
        try:
            os.chmod(zip_path, 0o640)
        except OSError:
            pass
        # Readable by www-data if group-owned
        try:
            shutil.chown(zip_path, user="root", group="www-data")
        except (OSError, LookupError, AttributeError, ImportError, NotImplementedError):
            try:
                import grp

                gid = grp.getgrnam("www-data").gr_gid
                os.chown(zip_path, 0, gid)
            except (OSError, KeyError, ImportError):
                pass

        size = zip_path.stat().st_size
        log(f"done: {nfiles} files, {size} bytes")
        if size > MAX_ZIP_BYTES:
            log(f"WARNING: zip exceeds soft limit {MAX_ZIP_BYTES} bytes")
        return zip_path
    finally:
        shutil.rmtree(work, ignore_errors=True)


def main(argv: Optional[list[str]] = None) -> int:
    ap = argparse.ArgumentParser(description="Build a NexBreak support bundle zip")
    ap.add_argument(
        "--hours",
        type=int,
        required=True,
        help=f"Journal/audit window; one of {sorted(ALLOWED_HOURS)}",
    )
    ap.add_argument(
        "--requestor-ip",
        default="",
        help="Client IP recorded in MANIFEST (from Services UI)",
    )
    ap.add_argument(
        "--out-dir",
        default="",
        help="Override support output directory",
    )
    args = ap.parse_args(argv)
    out = Path(args.out_dir) if args.out_dir else None
    path = build_bundle(
        hours=int(args.hours),
        requestor_ip=str(args.requestor_ip or "").strip(),
        out_dir=out,
    )
    # Single-line path for ops.php
    print(str(path.resolve()))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except SystemExit:
        raise
    except Exception as exc:  # noqa: BLE001
        print(f"support bundle failed: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
