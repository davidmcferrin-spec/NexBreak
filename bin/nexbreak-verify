#!/usr/bin/env python3
"""
nexbreak-verify — SCTE return-feed Verify API (isolated from the controller).

Owns listen/stop of nexbreak-scte-watch, SCTE state under
/var/lib/nexbreak/scte, and scte_sightings reads. stdlib only.
Default bind: 127.0.0.1:8788.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import subprocess
import sys
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any, Optional
from urllib.parse import urlparse

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_db import (  # noqa: E402
    audit,
    connect,
    migrate,
    row_to_dict,
    rows_to_dicts,
    splice_udp_port_for,
)
from nexbreak_verify import (  # noqa: E402
    empty_scte_state,
    probe_scte_feed,
    read_json,
    resolve_tap,
    scte_dir,
    scte_state_path,
    stop_watch_pid,
    watch_alive,
)

log = logging.getLogger("nexbreak-verify")
DB_PATH: Optional[str] = None


def db():
    return connect(DB_PATH)


def _routed_processing(conn, egress_id: int) -> Optional[dict[str, Any]]:
    row = conn.execute(
        """
        SELECT pc.*
        FROM routing_assignments ra
        JOIN processing_channels pc ON pc.id = ra.processing_channel_id
        WHERE ra.egress_channel_id = ?
        """,
        (egress_id,),
    ).fetchone()
    return row_to_dict(row)


def _verify_egress_row(conn, egress: dict[str, Any]) -> dict[str, Any]:
    proc = _routed_processing(conn, int(egress["id"]))
    tap = resolve_tap(egress, proc)
    return {
        "egress": egress,
        "processing": (
            {
                "id": proc["id"],
                "name": proc["name"],
                "service_name": proc["service_name"],
                "local_feed_host": proc.get("local_feed_host"),
                "local_feed_port": proc.get("local_feed_port"),
                "splice_insertion_delay_ms": proc.get("splice_insertion_delay_ms"),
            }
            if proc
            else None
        ),
        "tap": tap,
        "listening": watch_alive(int(egress["id"])),
    }


def _scte_watch_script() -> Path:
    return Path(__file__).resolve().parent / "nexbreak-scte-watch"


def _start_scte_watch(
    egress: dict[str, Any],
    *,
    processing: Optional[dict[str, Any]],
    tap: dict[str, Any],
    auto_inject_sec: float = 12.0,
) -> dict[str, Any]:
    eid = int(egress["id"])
    stop_watch_pid(eid)
    try:
        scte_dir(create=True)
    except OSError as exc:
        return {"ok": False, "error": f"cannot create SCTE state dir: {exc}"}
    script = _scte_watch_script()
    if not script.is_file():
        return {"ok": False, "error": f"missing {script}"}
    delay_ms = 2000
    if processing:
        delay_ms = int(processing.get("splice_insertion_delay_ms") or 2000)
    argv = [
        sys.executable,
        str(script),
        "--egress-id",
        str(eid),
        "--tap-url",
        tap["tap_url"],
        "--tap-kind",
        tap["tap_kind"],
        "--label",
        tap.get("label") or tap["tap_url"],
        "--delay-ms",
        str(delay_ms),
    ]
    if tap.get("tap_kind") == "feed":
        if tap.get("feed_host"):
            argv += ["--feed-host", str(tap["feed_host"])]
        if tap.get("feed_port"):
            argv += ["--feed-port", str(int(tap["feed_port"]))]
    if processing:
        argv += ["--processing-channel-id", str(processing["id"])]
        try:
            argv += ["--splice-udp-port", str(splice_udp_port_for(processing))]
        except Exception:
            pass
        if auto_inject_sec and auto_inject_sec > 0:
            argv += [
                "--auto-inject-sec",
                str(float(auto_inject_sec)),
                "--auto-inject-first-delay-sec",
                "2.5",
            ]
    if DB_PATH:
        argv += ["--db", DB_PATH]
    log_path = Path(os.environ.get("NEXBREAK_LOG_DIR", "/var/log/nexbreak")) / f"scte-watch-{eid}.log"
    try:
        log_path.parent.mkdir(parents=True, exist_ok=True)
        log_fh = open(log_path, "ab", buffering=0)
    except OSError:
        log_fh = subprocess.DEVNULL
    child_env = os.environ.copy()
    child_env.setdefault("NEXBREAK_RUN_DIR", os.environ.get("NEXBREAK_RUN_DIR", "/run/nexbreak"))
    child_env.setdefault("NEXBREAK_DATA", os.environ.get("NEXBREAK_DATA", "/var/lib/nexbreak"))
    child_env.setdefault(
        "NEXBREAK_SCTE_DIR",
        os.environ.get("NEXBREAK_SCTE_DIR", str(scte_dir())),
    )
    try:
        proc = subprocess.Popen(
            argv,
            stdin=subprocess.DEVNULL,
            stdout=log_fh,
            stderr=subprocess.STDOUT,
            # Stay in the service mount namespace so ReadWritePaths apply.
            start_new_session=False,
            env=child_env,
            cwd=str(Path(script).resolve().parent),
        )
    except Exception as exc:  # noqa: BLE001
        if log_fh is not subprocess.DEVNULL:
            try:
                log_fh.close()
            except Exception:
                pass
        return {"ok": False, "error": str(exc)}
    finally:
        if log_fh is not subprocess.DEVNULL:
            try:
                log_fh.close()
            except Exception:
                pass
    log.info("spawned scte-watch pid=%s egress=%s log=%s", proc.pid, eid, log_path)
    for _ in range(60):
        if watch_alive(eid):
            break
        # Child died before writing pid — surface quickly.
        if proc.poll() is not None:
            break
        time.sleep(0.05)
    alive = watch_alive(eid)
    live = read_json(scte_state_path(eid)) or empty_scte_state(eid, listening=alive)
    if not alive:
        err = live.get("error") or (
            f"scte-watch failed to start (exit={proc.poll()}; see {log_path})"
        )
        return {
            "ok": False,
            "error": err,
            "listening": False,
            "tap": tap,
            "live": live,
        }
    return {
        "ok": True,
        "listening": True,
        "tap": tap,
        "live": live,
        "auto_inject_sec": auto_inject_sec if processing else 0,
    }


class Handler(BaseHTTPRequestHandler):
    server_version = "NexBreakVerify/0.1"

    def log_message(self, fmt: str, *args: Any) -> None:
        log.info("%s - " + fmt, self.address_string(), *args)

    def _send(self, code: int, body: Any, content_type: str = "application/json") -> None:
        raw = body if isinstance(body, (bytes, bytearray)) else json.dumps(body).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(raw)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Headers", "Content-Type, Authorization, X-Api-Key")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.end_headers()
        self.wfile.write(raw)

    def do_OPTIONS(self) -> None:  # noqa: N802
        self._send(204, b"")

    def _read_json(self) -> dict[str, Any]:
        length = int(self.headers.get("Content-Length") or 0)
        if length <= 0:
            return {}
        raw = self.rfile.read(length)
        if not raw:
            return {}
        data = json.loads(raw.decode("utf-8"))
        return data if isinstance(data, dict) else {}

    def do_GET(self) -> None:  # noqa: N802
        path = urlparse(self.path).path.rstrip("/") or "/"

        if path in ("/", "/health", "/v1/health"):
            self._send(200, {"ok": True, "service": "nexbreak-verify"})
            return

        conn = db()
        try:
            if path == "/v1/verify/egresses":
                migrate(conn)
                rows = conn.execute(
                    "SELECT * FROM egress_channels ORDER BY id"
                ).fetchall()
                items = []
                for r in rows:
                    eg = row_to_dict(r)
                    assert eg is not None
                    items.append(_verify_egress_row(conn, eg))
                self._send(200, {"ok": True, "egresses": items})
                return

            if path.startswith("/v1/verify/") and path.endswith("/live"):
                migrate(conn)
                eid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT * FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "egress not found"})
                    return
                eg = row_to_dict(row)
                assert eg is not None
                info = _verify_egress_row(conn, eg)
                live = read_json(scte_state_path(eid)) or empty_scte_state(eid)
                live["listening"] = bool(live.get("listening")) and watch_alive(eid)
                sightings = []
                try:
                    sightings = rows_to_dicts(
                        conn.execute(
                            """
                            SELECT * FROM scte_sightings
                            WHERE egress_channel_id = ?
                            ORDER BY id DESC
                            LIMIT 80
                            """,
                            (eid,),
                        ).fetchall()
                    )
                except Exception:
                    sightings = []
                self._send(
                    200,
                    {
                        "ok": True,
                        **info,
                        "live": live,
                        "sightings": sightings,
                    },
                )
                return

            self._send(404, {"ok": False, "error": f"unknown path {path}"})
        except Exception as exc:  # noqa: BLE001
            log.exception("GET %s failed", path)
            self._send(500, {"ok": False, "error": str(exc)})
        finally:
            conn.close()

    def do_POST(self) -> None:  # noqa: N802
        path = urlparse(self.path).path.rstrip("/") or "/"
        _body = self._read_json()
        conn = db()
        try:
            if path.startswith("/v1/verify/") and path.endswith("/listen"):
                eid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT * FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "egress not found"})
                    return
                eg = row_to_dict(row)
                assert eg is not None
                proc = _routed_processing(conn, eid)
                tap = resolve_tap(eg, proc)
                if not tap.get("ok"):
                    self._send(400, {"ok": False, "error": tap.get("error") or "tap failed"})
                    return
                auto_sec = 12.0
                if isinstance(_body, dict) and _body.get("auto_inject_sec") is not None:
                    try:
                        auto_sec = float(_body["auto_inject_sec"])
                    except (TypeError, ValueError):
                        auto_sec = 12.0
                # Listen owns continuous verify: watch + periodic test injects until Stop.
                result = _start_scte_watch(
                    eg,
                    processing=proc,
                    tap=tap,
                    auto_inject_sec=auto_sec,
                )
                if not result.get("ok"):
                    self._send(502, result)
                    return
                audit(
                    conn,
                    event_type="config_change",
                    egress_channel_id=eid,
                    processing_channel_id=proc["id"] if proc else None,
                    source_ip=self.client_address[0],
                    result="success",
                    detail=(
                        f"scte verify listen kind={tap.get('tap_kind')} "
                        f"auto_inject={auto_sec}s {tap.get('label')}"
                    ),
                )
                self._send(200, result)
                return

            if path.startswith("/v1/verify/") and path.endswith("/stop"):
                eid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT * FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "egress not found"})
                    return
                stop_watch_pid(eid)
                audit(
                    conn,
                    event_type="config_change",
                    egress_channel_id=eid,
                    source_ip=self.client_address[0],
                    result="success",
                    detail="scte verify stop",
                )
                self._send(
                    200,
                    {
                        "ok": True,
                        "listening": False,
                        "live": read_json(scte_state_path(eid))
                        or empty_scte_state(eid),
                    },
                )
                return

            if path.startswith("/v1/verify/") and path.endswith("/probe"):
                eid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT * FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "egress not found"})
                    return
                eg = row_to_dict(row)
                assert eg is not None
                proc = _routed_processing(conn, eid)
                tap = resolve_tap(eg, proc)
                if not tap.get("ok") or tap.get("tap_kind") != "feed":
                    self._send(
                        400,
                        {
                            "ok": False,
                            "error": (
                                tap.get("error")
                                or "probe needs a routed post-splice feed tap"
                            ),
                            "tap": tap,
                        },
                    )
                    return
                duration = 10.0
                if isinstance(_body, dict) and _body.get("duration_s") is not None:
                    try:
                        duration = float(_body["duration_s"])
                    except (TypeError, ValueError):
                        duration = 10.0
                fire = True
                if isinstance(_body, dict) and "fire_test_splice" in _body:
                    fire = bool(_body.get("fire_test_splice"))
                scte_pid = None
                splice_udp = None
                if proc:
                    try:
                        scte_pid = int(proc.get("scte35_pid") or 500)
                    except (TypeError, ValueError):
                        scte_pid = 500
                    try:
                        from nexbreak_db import splice_udp_port_for

                        splice_udp = splice_udp_port_for(proc)
                    except Exception:
                        splice_udp = None
                result = probe_scte_feed(
                    str(tap["feed_host"]),
                    int(tap["feed_port"]),
                    duration_s=duration,
                    scte_pid=scte_pid,
                    splice_udp_port=splice_udp,
                    fire_test_splice=fire,
                )
                audit(
                    conn,
                    event_type="config_change",
                    egress_channel_id=eid,
                    processing_channel_id=proc["id"] if proc else None,
                    source_ip=self.client_address[0],
                    result="success" if result.get("ok") else "failure",
                    detail=(
                        f"scte probe verdict={result.get('verdict')} "
                        f"sections={result.get('section_count')} "
                        f"pmt={result.get('pmt_scte_pids')} "
                        f"test_inject={result.get('test_inject')}"
                    ),
                )
                status = 200 if result.get("ok") else 502
                self._send(
                    status,
                    {
                        **result,
                        "egress_id": eid,
                        "tap": tap,
                        "inject_note": (
                            "Probe auto-fires a splice_start_immediate into "
                            "tsp spliceinject mid-window (unless "
                            "fire_test_splice=false). PMT-only without "
                            "sections after that means inject is not on the wire."
                        ),
                    },
                )
                return

            self._send(404, {"ok": False, "error": f"unknown path {path}"})
        except (KeyError, ValueError, TypeError) as exc:
            self._send(400, {"ok": False, "error": str(exc)})
        except Exception as exc:  # noqa: BLE001
            log.exception("POST %s failed", path)
            self._send(500, {"ok": False, "error": str(exc)})
        finally:
            conn.close()


def main() -> int:
    global DB_PATH

    parser = argparse.ArgumentParser(description="NexBreak SCTE Verify API")
    parser.add_argument("--db", default=None)
    parser.add_argument(
        "--host",
        default=os.environ.get("NEXBREAK_VERIFY_HOST", "127.0.0.1"),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.environ.get("NEXBREAK_VERIFY_PORT", "8788")),
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )

    DB_PATH = args.db or os.environ.get(
        "NEXBREAK_DB", "/var/lib/nexbreak/nexbreak.sqlite"
    )
    try:
        scte = scte_dir(create=True)
        log.info("SCTE state dir %s", scte)
    except OSError as exc:
        log.error("cannot create SCTE state dir: %s", exc)
        return 1
    conn = connect(DB_PATH)
    try:
        migrate(conn)
    finally:
        conn.close()

    httpd = ThreadingHTTPServer((args.host, args.port), Handler)
    log.info("nexbreak-verify listening on http://%s:%s db=%s", args.host, args.port, DB_PATH)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        log.info("shutting down")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
