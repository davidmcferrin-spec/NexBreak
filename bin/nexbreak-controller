#!/usr/bin/env python3
"""
nexbreak-controller — HTTP control API + SQLite owner.

Serves REST for the web UI, Streamdeck, and DNF panel. stdlib only.
Default bind: 127.0.0.1:8787 (Apache/PHP reverse-proxies or same-origin fetch).
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any, Optional
from urllib.parse import parse_qs, urlparse

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_db import (  # noqa: E402
    SPLICE_TYPES,
    audit,
    connect,
    control_sock_path,
    delete_splice_preset,
    get_splice_preset,
    init_schema,
    list_splice_presets,
    migrate,
    preview_path_for,
    row_to_dict,
    rows_to_dicts,
    upsert_splice_preset,
)
from nexbreak_pipeline import enrich_channel_bitrate  # noqa: E402
from nexbreak_control import send_caption_set, send_caption_status, send_splice  # noqa: E402


log = logging.getLogger("nexbreak-controller")
DB_PATH: Optional[str] = None
WHEP_PORT = int(os.environ.get("NEXBREAK_WHEP_PORT", "8889"))
MEDIAMTX_API = os.environ.get("NEXBREAK_MEDIAMTX_API", "http://127.0.0.1:9997")


def db():
    return connect(DB_PATH)


def _as_bool(value: Any, default: bool = False) -> bool:
    """Parse bools from JSON (bool/int) or query strings ("false", "0", …)."""
    if value is None or value == "":
        return default
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return value != 0
    s = str(value).strip().lower()
    if s in ("1", "true", "yes", "on"):
        return True
    if s in ("0", "false", "no", "off"):
        return False
    return default


def _resolve_splice_request(
    conn, body: dict[str, Any]
) -> tuple[Optional[dict[str, Any]], Optional[dict[str, Any]], Optional[str]]:
    """
    Resolve channel + splice params from body/query.
    Returns (channel, fire_fields, error).
    fire_fields: splice_type, hex_payload, auto_return, break_duration_sec, use_channel_delay, preset
    """
    try:
        channel_id = int(body.get("processing_channel_id") or 0)
    except (TypeError, ValueError):
        return None, None, "processing_channel_id required"
    if channel_id <= 0:
        return None, None, "processing_channel_id required"
    row = conn.execute(
        "SELECT * FROM processing_channels WHERE id = ?", (channel_id,)
    ).fetchone()
    if not row:
        return None, None, "processing channel not found"
    channel = row_to_dict(row)
    assert channel is not None

    preset = None
    preset_id = body.get("preset_id")
    preset_slug = body.get("preset") or body.get("slug")
    if preset_id is not None and str(preset_id).strip() != "":
        try:
            preset = get_splice_preset(conn, preset_id=int(preset_id))
        except (TypeError, ValueError):
            return None, None, "invalid preset_id"
        if not preset:
            return None, None, "preset not found"
    elif preset_slug:
        preset = get_splice_preset(conn, slug=str(preset_slug).strip())
        if not preset:
            return None, None, f"preset not found: {preset_slug}"
        if not int(preset.get("enabled") or 0):
            return None, None, f"preset disabled: {preset_slug}"

    if preset:
        fire = {
            "splice_type": preset["splice_type"],
            "hex_payload": preset.get("hex_payload"),
            "auto_return": bool(int(preset.get("auto_return") or 0)),
            "break_duration_sec": preset.get("break_duration_sec"),
            "use_channel_delay": bool(int(preset.get("use_channel_delay", 1))),
            "preset": preset,
        }
    else:
        splice_type = body.get("splice_type") or "splice_start_immediate"
        if splice_type not in SPLICE_TYPES:
            return None, None, f"invalid splice_type {splice_type}"
        br = body.get("break_duration_sec")
        fire = {
            "splice_type": splice_type,
            "hex_payload": body.get("hex_payload"),
            "auto_return": _as_bool(body.get("auto_return"), False),
            "break_duration_sec": float(br) if br not in (None, "") else None,
            "use_channel_delay": _as_bool(
                body.get("use_channel_delay", True), True
            ),
            "preset": None,
        }
    return channel, fire, None


def _execute_splice(
    conn,
    *,
    channel: dict[str, Any],
    fire: dict[str, Any],
    source_ip: str,
) -> tuple[int, dict[str, Any]]:
    """Run splice against proc; audit; return (http_code, body)."""
    channel_id = int(channel["id"])
    splice_type = fire["splice_type"]
    hex_payload = fire.get("hex_payload")
    sock = control_sock_path(channel["service_name"])
    delay_ms = int(channel.get("splice_insertion_delay_ms") or 0)
    if not fire.get("use_channel_delay") or splice_type == "splice_cancel":
        delay_ms = 0
    timeout = max(30.0, delay_ms / 1000.0 + 15.0)
    preset = fire.get("preset")
    detail_prefix = f"preset={preset['slug']} " if preset else ""

    try:
        result = send_splice(
            sock,
            splice_type=splice_type,
            hex_payload=hex_payload,
            auto_return=bool(fire.get("auto_return")),
            break_duration_sec=fire.get("break_duration_sec"),
            use_channel_delay=bool(fire.get("use_channel_delay", True)),
            timeout=timeout,
        )
    except FileNotFoundError:
        eid = audit(
            conn,
            event_type="splice_command",
            processing_channel_id=channel_id,
            splice_type=splice_type,
            splice_hex_payload=hex_payload,
            source_ip=source_ip,
            result="failure",
            detail=f"{detail_prefix}proc socket missing: {sock}",
        )
        return 503, {
            "ok": False,
            "audit_id": eid,
            "error": f"processing service not running ({sock})",
        }
    except Exception as exc:  # noqa: BLE001
        eid = audit(
            conn,
            event_type="splice_command",
            processing_channel_id=channel_id,
            splice_type=splice_type,
            splice_hex_payload=hex_payload,
            source_ip=source_ip,
            result="failure",
            detail=f"{detail_prefix}{exc}",
        )
        return 502, {"ok": False, "audit_id": eid, "error": str(exc)}

    ok = bool(result.get("ok"))
    eid = audit(
        conn,
        event_type="splice_command",
        processing_channel_id=channel_id,
        splice_type=splice_type,
        splice_hex_payload=hex_payload,
        source_ip=source_ip,
        result="success" if ok else "failure",
        detail=detail_prefix + (result.get("detail") or result.get("error") or ""),
    )
    body = {
        "ok": ok,
        "audit_id": eid,
        "delay_ms": result.get("delay_ms", delay_ms),
        "event_id": result.get("event_id"),
        "splice_type": splice_type,
        "message": result.get("detail") or result.get("error"),
    }
    if preset:
        body["preset"] = {"id": preset["id"], "slug": preset["slug"], "label": preset["label"]}
    return (202 if ok else 502), body


def _enrich_egress_bitrate(conn, egress: dict[str, Any]) -> dict[str, Any]:
    """Copy sensed/output from the routed processing channel when available."""
    out = enrich_channel_bitrate(egress)
    row = conn.execute(
        """
        SELECT pc.service_name, pc.target_bitrate_kbps
        FROM routing_assignments ra
        JOIN processing_channels pc ON pc.id = ra.processing_channel_id
        WHERE ra.egress_channel_id = ?
        """,
        (int(egress["id"]),),
    ).fetchone()
    if not row:
        return out
    proc = enrich_channel_bitrate(
        {
            "service_name": row["service_name"],
            "target_bitrate_kbps": row["target_bitrate_kbps"],
        }
    )
    if proc.get("sensed_bitrate_kbps") is not None:
        out["sensed_bitrate_kbps"] = proc["sensed_bitrate_kbps"]
    if proc.get("output_bitrate_kbps") is not None:
        out["output_bitrate_kbps"] = proc["output_bitrate_kbps"]
    return out


def seed_demo(conn) -> None:
    """Create four demo processing + egress channels if the tables are empty."""
    n = conn.execute("SELECT COUNT(*) AS c FROM processing_channels").fetchone()["c"]
    if n:
        return
    for i in range(1, 5):
        conn.execute(
            """
            INSERT INTO processing_channels (
                name, service_name, input_type, rtsp_role, rtsp_url,
                video_codec, audio_codec, target_bitrate_kbps,
                splice_insertion_delay_ms, captioning_enabled,
                local_feed_host, local_feed_port, enabled
            ) VALUES (?, ?, 'rtsp', 'client_pull', ?, 'h264', 'aac', 14000, 2000, 0, '127.0.0.1', ?, 1)
            """,
            (f"Input {i}", str(i), f"rtsp://source.example/ch{i}", 19000 + i),
        )
        conn.execute(
            """
            INSERT INTO egress_channels (
                name, service_name, output_type, srt_mode, srt_listen_port,
                target_bitrate_kbps, enabled
            ) VALUES (?, ?, 'srt', 'listener', ?, 14000, 1)
            """,
            (f"Output {i}", str(i), 9000 + i),
        )
    # Default 1:1 routing
    for i in range(1, 5):
        conn.execute(
            "INSERT INTO routing_assignments (processing_channel_id, egress_channel_id) VALUES (?, ?)",
            (i, i),
        )
    conn.commit()
    log.info("seeded demo processing/egress channels 1–4 with 1:1 routing")


class Handler(BaseHTTPRequestHandler):
    server_version = "NexBreakController/0.1"

    def log_message(self, fmt: str, *args: Any) -> None:
        log.info("%s - " + fmt, self.address_string(), *args)

    def _send(self, code: int, body: Any, content_type: str = "application/json") -> None:
        raw = body if isinstance(body, (bytes, bytearray)) else json.dumps(body).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(raw)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Headers", "Content-Type, Authorization, X-Api-Key")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, PATCH, DELETE, OPTIONS")
        self.end_headers()
        self.wfile.write(raw)

    def _read_json(self) -> dict[str, Any]:
        length = int(self.headers.get("Content-Length") or 0)
        if length <= 0:
            return {}
        raw = self.rfile.read(length)
        if not raw:
            return {}
        return json.loads(raw.decode("utf-8"))

    def do_OPTIONS(self) -> None:  # noqa: N802
        self._send(204, b"")

    def do_GET(self) -> None:  # noqa: N802
        path = urlparse(self.path).path.rstrip("/") or "/"
        qs = parse_qs(urlparse(self.path).query)

        if path in ("/", "/health", "/v1/health"):
            self._send(200, {"ok": True, "service": "nexbreak-controller"})
            return

        conn = db()
        try:
            if path == "/v1/processing":
                rows = conn.execute(
                    "SELECT * FROM processing_channels ORDER BY id"
                ).fetchall()
                channels = [enrich_channel_bitrate(c) for c in rows_to_dicts(rows)]
                self._send(200, {"ok": True, "channels": channels})
                return

            if path.startswith("/v1/processing/") and path.count("/") == 3:
                cid = int(path.rsplit("/", 1)[-1])
                row = conn.execute(
                    "SELECT * FROM processing_channels WHERE id = ?", (cid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "not found"})
                    return
                ch = row_to_dict(row)
                assert ch is not None
                self._send(200, {"ok": True, "channel": enrich_channel_bitrate(ch)})
                return

            if path.startswith("/v1/processing/") and path.endswith("/captioning"):
                cid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT * FROM processing_channels WHERE id = ?", (cid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "not found"})
                    return
                ch = row_to_dict(row)
                assert ch is not None
                from nexbreak_caption_policy import normalize_policy

                policy = normalize_policy(
                    ch.get("caption_policy"),
                    captioning_enabled=ch.get("captioning_enabled"),
                )
                runtime = None
                sock = control_sock_path(ch["service_name"])
                try:
                    runtime = send_caption_status(sock)
                except FileNotFoundError:
                    from nexbreak_captions import read_asr_live

                    runtime = {
                        "ok": True,
                        "desired": policy != "off",
                        "running": False,
                        "bypassed": policy == "off",
                        "policy": policy,
                        "source_has_cc": None,
                        "effective_mode": None,
                        "note": "proc not running",
                        "asr": read_asr_live(str(ch["service_name"])) or {},
                    }
                except Exception as exc:  # noqa: BLE001
                    runtime = {"ok": False, "error": str(exc)}
                else:
                    if isinstance(runtime, dict) and "asr" not in runtime:
                        from nexbreak_captions import read_asr_live

                        runtime["asr"] = read_asr_live(str(ch["service_name"])) or {}
                self._send(
                    200,
                    {
                        "ok": True,
                        "enabled": 0 if policy == "off" else 1,
                        "policy": policy,
                        "runtime": runtime,
                    },
                )
                return

            if path == "/v1/egress":
                rows = conn.execute("SELECT * FROM egress_channels ORDER BY id").fetchall()
                items = []
                for r in rows:
                    eg = row_to_dict(r)
                    assert eg is not None
                    items.append(_enrich_egress_bitrate(conn, eg))
                self._send(200, {"ok": True, "channels": items})
                return

            if path.startswith("/v1/egress/") and path.count("/") == 3:
                eid = int(path.rsplit("/", 1)[-1])
                row = conn.execute(
                    "SELECT * FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "not found"})
                    return
                eg = row_to_dict(row)
                assert eg is not None
                self._send(200, {"ok": True, "channel": _enrich_egress_bitrate(conn, eg)})
                return

            if path == "/v1/metrics":
                # Operational metrics from audit_events (not viewer analytics).
                range_key = (qs.get("range") or ["24h"])[0]
                ranges = {
                    "15m": (15 * 60, 60),
                    "1h": (3600, 300),
                    "6h": (6 * 3600, 900),
                    "24h": (86400, 3600),
                    "7d": (7 * 86400, 6 * 3600),
                }
                if range_key not in ranges:
                    self._send(400, {"ok": False, "error": "invalid range"})
                    return
                span_s, bucket_s = ranges[range_key]
                since_expr = f"-{span_s} seconds"
                # Bucket labels via unixepoch flooring (SQLite 3.38+ / Ubuntu 24).
                rows = conn.execute(
                    """
                    SELECT
                      (CAST(strftime('%s', occurred_at) AS INTEGER) / ?) * ? AS bucket_ts,
                      event_type,
                      COALESCE(result, '') AS result,
                      COUNT(*) AS n
                    FROM audit_events
                    WHERE occurred_at >= datetime('now', ?)
                    GROUP BY 1, 2, 3
                    ORDER BY 1
                    """,
                    (bucket_s, bucket_s, since_expr),
                ).fetchall()
                by_channel = conn.execute(
                    """
                    SELECT
                      ae.processing_channel_id AS id,
                      pc.name AS name,
                      SUM(CASE WHEN ae.event_type = 'splice_command' THEN 1 ELSE 0 END) AS splices,
                      SUM(CASE WHEN ae.event_type = 'splice_command' AND ae.result = 'success' THEN 1 ELSE 0 END) AS splice_ok,
                      SUM(CASE WHEN ae.event_type = 'splice_command' AND ae.result = 'failure' THEN 1 ELSE 0 END) AS splice_fail,
                      SUM(CASE WHEN ae.event_type = 'config_change' THEN 1 ELSE 0 END) AS config_changes
                    FROM audit_events ae
                    LEFT JOIN processing_channels pc ON pc.id = ae.processing_channel_id
                    WHERE ae.occurred_at >= datetime('now', ?)
                      AND ae.processing_channel_id IS NOT NULL
                    GROUP BY ae.processing_channel_id
                    ORDER BY ae.processing_channel_id
                    """,
                    (since_expr,),
                ).fetchall()
                totals = conn.execute(
                    """
                    SELECT
                      SUM(CASE WHEN event_type = 'splice_command' THEN 1 ELSE 0 END) AS splices,
                      SUM(CASE WHEN event_type = 'splice_command' AND result = 'success' THEN 1 ELSE 0 END) AS splice_ok,
                      SUM(CASE WHEN event_type = 'splice_command' AND result = 'failure' THEN 1 ELSE 0 END) AS splice_fail,
                      SUM(CASE WHEN event_type = 'routing_change' THEN 1 ELSE 0 END) AS routing_changes,
                      SUM(CASE WHEN event_type = 'config_change' THEN 1 ELSE 0 END) AS config_changes,
                      SUM(CASE WHEN event_type = 'service_lifecycle' THEN 1 ELSE 0 END) AS lifecycle_events
                    FROM audit_events
                    WHERE occurred_at >= datetime('now', ?)
                    """,
                    (since_expr,),
                ).fetchone()
                proc = conn.execute(
                    "SELECT id, name, enabled, input_type, captioning_enabled FROM processing_channels ORDER BY id"
                ).fetchall()
                egr = conn.execute(
                    "SELECT id, name, enabled, output_type, srt_mode FROM egress_channels ORDER BY id"
                ).fetchall()
                routes = conn.execute(
                    """
                    SELECT ra.processing_channel_id, ra.egress_channel_id,
                           pc.name AS processing_name, ec.name AS egress_name
                    FROM routing_assignments ra
                    JOIN processing_channels pc ON pc.id = ra.processing_channel_id
                    JOIN egress_channels ec ON ec.id = ra.egress_channel_id
                    ORDER BY ec.id
                    """
                ).fetchall()
                self._send(
                    200,
                    {
                        "ok": True,
                        "range": range_key,
                        "bucket_seconds": bucket_s,
                        "span_seconds": span_s,
                        "totals": row_to_dict(totals) or {},
                        "series": rows_to_dicts(rows),
                        "by_channel": rows_to_dicts(by_channel),
                        "channels": {
                            "processing": rows_to_dicts(proc),
                            "egress": rows_to_dicts(egr),
                            "routes": rows_to_dicts(routes),
                        },
                    },
                )
                return

            if path == "/v1/routing":
                rows = conn.execute(
                    """
                    SELECT ra.id, ra.processing_channel_id, ra.egress_channel_id, ra.assigned_at,
                           pc.name AS processing_name, ec.name AS egress_name
                    FROM routing_assignments ra
                    JOIN processing_channels pc ON pc.id = ra.processing_channel_id
                    JOIN egress_channels ec ON ec.id = ra.egress_channel_id
                    ORDER BY ec.id
                    """
                ).fetchall()
                self._send(200, {"ok": True, "assignments": rows_to_dicts(rows)})
                return

            if path == "/v1/audit":
                limit = int((qs.get("limit") or ["50"])[0])
                limit = max(1, min(limit, 500))
                clauses: list[str] = []
                params: list[Any] = []
                et = (qs.get("event_type") or [None])[0]
                if et:
                    clauses.append("ae.event_type = ?")
                    params.append(et)
                pcid = (qs.get("processing_channel_id") or [None])[0]
                if pcid:
                    clauses.append("ae.processing_channel_id = ?")
                    params.append(int(pcid))
                where = (" WHERE " + " AND ".join(clauses)) if clauses else ""
                params.append(limit)
                rows = conn.execute(
                    f"""
                    SELECT ae.*, pc.name AS processing_name, ec.name AS egress_name,
                           cc.label AS credential_label
                    FROM audit_events ae
                    LEFT JOIN processing_channels pc ON pc.id = ae.processing_channel_id
                    LEFT JOIN egress_channels ec ON ec.id = ae.egress_channel_id
                    LEFT JOIN control_credentials cc ON cc.id = ae.triggered_by_credential_id
                    {where}
                    ORDER BY ae.occurred_at DESC, ae.id DESC
                    LIMIT ?
                    """,
                    params,
                ).fetchall()
                self._send(200, {"ok": True, "events": rows_to_dicts(rows)})
                return

            if path == "/v1/splice/presets":
                migrate(conn)
                enabled_only = (qs.get("enabled") or [""])[0] in ("1", "true", "yes")
                self._send(
                    200,
                    {
                        "ok": True,
                        "presets": list_splice_presets(conn, enabled_only=enabled_only),
                    },
                )
                return

            if path.startswith("/v1/splice/presets/"):
                migrate(conn)
                pid = int(path.split("/")[4])
                preset = get_splice_preset(conn, preset_id=pid)
                if not preset:
                    self._send(404, {"ok": False, "error": "preset not found"})
                    return
                self._send(200, {"ok": True, "preset": preset})
                return

            if path == "/v1/splice":
                # Panel-friendly GET fire (DNF / StreamDeck).
                migrate(conn)
                body = {k: (v[0] if v else None) for k, v in qs.items()}
                channel, fire, err = _resolve_splice_request(conn, body)
                if err or not channel or not fire:
                    self._send(400, {"ok": False, "error": err or "bad request"})
                    return
                code, resp = _execute_splice(
                    conn,
                    channel=channel,
                    fire=fire,
                    source_ip=self.client_address[0],
                )
                self._send(code, resp)
                return

            if path == "/v1/captions/lexicon":
                rows = conn.execute(
                    "SELECT * FROM caption_lexicon ORDER BY word COLLATE NOCASE"
                ).fetchall()
                self._send(200, {"ok": True, "entries": rows_to_dicts(rows)})
                return

            if path == "/v1/captions/blacklist":
                rows = conn.execute(
                    "SELECT * FROM caption_blacklist ORDER BY word COLLATE NOCASE"
                ).fetchall()
                self._send(200, {"ok": True, "entries": rows_to_dicts(rows)})
                return

            if path == "/v1/dashboard":
                proc = conn.execute(
                    "SELECT COUNT(*) AS c FROM processing_channels WHERE enabled = 1"
                ).fetchone()["c"]
                egr = conn.execute(
                    "SELECT COUNT(*) AS c FROM egress_channels WHERE enabled = 1"
                ).fetchone()["c"]
                routes = conn.execute(
                    "SELECT COUNT(*) AS c FROM routing_assignments"
                ).fetchone()["c"]
                splices = conn.execute(
                    "SELECT COUNT(*) AS c FROM audit_events WHERE event_type = 'splice_command'"
                ).fetchone()["c"]
                recent = conn.execute(
                    """
                    SELECT ae.*, pc.name AS processing_name
                    FROM audit_events ae
                    LEFT JOIN processing_channels pc ON pc.id = ae.processing_channel_id
                    ORDER BY ae.occurred_at DESC, ae.id DESC
                    LIMIT 12
                    """
                ).fetchall()
                self._send(
                    200,
                    {
                        "ok": True,
                        "stats": {
                            "processing_enabled": proc,
                            "egress_enabled": egr,
                            "routes": routes,
                            "splice_events": splices,
                        },
                        "recent": rows_to_dicts(recent),
                        "preview": {
                            "whep_port": WHEP_PORT,
                            "mediamtx_api": MEDIAMTX_API,
                        },
                    },
                )
                return

            if path == "/v1/preview":
                rows = conn.execute(
                    "SELECT * FROM processing_channels WHERE enabled = 1 ORDER BY id"
                ).fetchall()
                channels = []
                for r in rows:
                    ch = row_to_dict(r)
                    assert ch is not None
                    enabled = int(
                        ch.get("preview_enabled")
                        if ch.get("preview_enabled") is not None
                        else 1
                    )
                    channels.append(
                        {
                            "id": ch["id"],
                            "name": ch["name"],
                            "service_name": ch["service_name"],
                            "preview_enabled": enabled,
                            "preview_path": preview_path_for(ch),
                            "input_type": ch["input_type"],
                            "rtsp_url": ch.get("rtsp_url"),
                        }
                    )
                self._send(
                    200,
                    {
                        "ok": True,
                        "whep_port": WHEP_PORT,
                        "channels": channels,
                    },
                )
                return

            self._send(404, {"ok": False, "error": f"unknown path {path}"})
        except Exception as exc:  # noqa: BLE001
            log.exception("GET %s failed", path)
            self._send(500, {"ok": False, "error": str(exc)})
        finally:
            conn.close()

    def do_POST(self) -> None:  # noqa: N802
        path = urlparse(self.path).path.rstrip("/") or "/"
        body = self._read_json()
        conn = db()
        try:
            if path == "/v1/splice":
                # Panel / Streamdeck / roll-button entry point.
                migrate(conn)
                channel, fire, err = _resolve_splice_request(conn, body)
                if err or not channel or not fire:
                    code = 404 if err and "not found" in err else 400
                    self._send(code, {"ok": False, "error": err or "bad request"})
                    return
                code, resp = _execute_splice(
                    conn,
                    channel=channel,
                    fire=fire,
                    source_ip=self.client_address[0],
                )
                self._send(code, resp)
                return

            if path == "/v1/splice/presets":
                migrate(conn)
                try:
                    preset = upsert_splice_preset(conn, body)
                except ValueError as exc:
                    self._send(400, {"ok": False, "error": str(exc)})
                    return
                except Exception as exc:  # noqa: BLE001
                    self._send(400, {"ok": False, "error": str(exc)})
                    return
                audit(
                    conn,
                    event_type="config_change",
                    source_ip=self.client_address[0],
                    result="success",
                    detail=f"splice preset create slug={preset.get('slug')}",
                )
                self._send(200, {"ok": True, "preset": preset})
                return

            if path.startswith("/v1/splice/presets/"):
                migrate(conn)
                pid = int(path.split("/")[4])
                if body.get("delete") or body.get("_method") == "DELETE":
                    ok = delete_splice_preset(conn, pid)
                    if not ok:
                        self._send(404, {"ok": False, "error": "preset not found"})
                        return
                    audit(
                        conn,
                        event_type="config_change",
                        source_ip=self.client_address[0],
                        result="success",
                        detail=f"splice preset delete id={pid}",
                    )
                    self._send(200, {"ok": True})
                    return
                try:
                    preset = upsert_splice_preset(conn, body, preset_id=pid)
                except ValueError as exc:
                    self._send(400, {"ok": False, "error": str(exc)})
                    return
                audit(
                    conn,
                    event_type="config_change",
                    source_ip=self.client_address[0],
                    result="success",
                    detail=f"splice preset update slug={preset.get('slug')}",
                )
                self._send(200, {"ok": True, "preset": preset})
                return

            if path == "/v1/routing":
                proc_id = int(body["processing_channel_id"])
                egr_id = int(body["egress_channel_id"])
                conn.execute(
                    "DELETE FROM routing_assignments WHERE egress_channel_id = ?",
                    (egr_id,),
                )
                conn.execute(
                    """
                    INSERT INTO routing_assignments (processing_channel_id, egress_channel_id)
                    VALUES (?, ?)
                    """,
                    (proc_id, egr_id),
                )
                conn.commit()
                audit(
                    conn,
                    event_type="routing_change",
                    processing_channel_id=proc_id,
                    egress_channel_id=egr_id,
                    source_ip=self.client_address[0],
                    result="success",
                    detail=f"egress {egr_id} ← processing {proc_id}",
                )
                self._send(200, {"ok": True})
                return

            if path == "/v1/captions/lexicon":
                word = (body.get("word") or "").strip()
                phonetic = (body.get("phonetic") or "").strip()
                if not word or not phonetic:
                    self._send(400, {"ok": False, "error": "word and phonetic required"})
                    return
                conn.execute(
                    "INSERT INTO caption_lexicon (word, phonetic) VALUES (?, ?)",
                    (word, phonetic),
                )
                conn.commit()
                self._send(201, {"ok": True})
                return

            if path == "/v1/captions/blacklist":
                word = (body.get("word") or "").strip()
                if not word:
                    self._send(400, {"ok": False, "error": "word required"})
                    return
                conn.execute(
                    "INSERT INTO caption_blacklist (word) VALUES (?)",
                    (word,),
                )
                conn.commit()
                self._send(201, {"ok": True})
                return

            if path.startswith("/v1/processing/") and path.endswith("/config"):
                cid = int(path.split("/")[3])
                allowed = {
                    "name",
                    "input_type",
                    "srt_mode",
                    "srt_remote_host",
                    "srt_remote_port",
                    "srt_listen_port",
                    "rtsp_role",
                    "rtsp_url",
                    "rtsp_transport",
                    "decklink_device_index",
                    "video_codec",
                    "audio_codec",
                    "target_bitrate_kbps",
                    "ingest_mode",
                    "splice_insertion_delay_ms",
                    "scte35_pid",
                    "splice_udp_port",
                    "captioning_enabled",
                    "caption_policy",
                    "preview_enabled",
                    "preview_path",
                    "local_feed_host",
                    "local_feed_port",
                    "enabled",
                }
                fields = {k: body[k] for k in allowed if k in body}
                if not fields:
                    self._send(400, {"ok": False, "error": "no updatable fields"})
                    return
                from nexbreak_caption_policy import apply_policy_fields, normalize_policy

                fields = apply_policy_fields(fields)
                if "caption_policy" in fields and fields["caption_policy"] not in (
                    "off",
                    "auto",
                    "force_asr",
                ):
                    self._send(400, {"ok": False, "error": "invalid caption_policy"})
                    return
                if "input_type" in fields and fields["input_type"] not in (
                    "rtsp",
                    "srt",
                    "decklink",
                ):
                    self._send(400, {"ok": False, "error": "invalid input_type"})
                    return
                if "srt_mode" in fields and fields["srt_mode"] not in (
                    None,
                    "",
                    "caller",
                    "listener",
                    "rendezvous",
                ):
                    self._send(400, {"ok": False, "error": "invalid srt_mode"})
                    return
                if "rtsp_role" in fields and fields["rtsp_role"] not in (
                    None,
                    "",
                    "client_pull",
                    "server_push",
                ):
                    self._send(400, {"ok": False, "error": "invalid rtsp_role"})
                    return
                for key in (
                    "srt_remote_host",
                    "rtsp_url",
                    "preview_path",
                    "srt_mode",
                    "rtsp_role",
                ):
                    if key in fields and fields[key] == "":
                        fields[key] = None
                for key in (
                    "srt_remote_port",
                    "srt_listen_port",
                    "decklink_device_index",
                    "target_bitrate_kbps",
                ):
                    if key in fields and fields[key] in ("", None):
                        fields[key] = None
                    elif key in fields:
                        fields[key] = int(fields[key])
                for key in (
                    "captioning_enabled",
                    "preview_enabled",
                    "enabled",
                ):
                    if key in fields:
                        fields[key] = (
                            1
                            if fields[key] in (True, 1, "1", "true", "on")
                            else 0
                        )
                if "caption_policy" in fields:
                    fields["caption_policy"] = normalize_policy(fields["caption_policy"])
                    fields["captioning_enabled"] = (
                        0 if fields["caption_policy"] == "off" else 1
                    )
                # Reject incomplete SRT caller/listener configs up front.
                row = conn.execute(
                    "SELECT * FROM processing_channels WHERE id = ?", (cid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "not found"})
                    return
                merged = dict(row_to_dict(row) or {})
                merged.update(fields)
                if merged.get("input_type") == "srt":
                    mode = (merged.get("srt_mode") or "caller").lower()
                    if mode == "listener":
                        if not merged.get("srt_listen_port"):
                            self._send(
                                400,
                                {
                                    "ok": False,
                                    "error": "srt_listen_port required for SRT listener",
                                },
                            )
                            return
                    elif not merged.get("srt_remote_host") or not merged.get(
                        "srt_remote_port"
                    ):
                        self._send(
                            400,
                            {
                                "ok": False,
                                "error": "srt_remote_host and srt_remote_port required for SRT caller/rendezvous",
                            },
                        )
                        return
                sets = ", ".join(f"{k} = ?" for k in fields)
                vals = list(fields.values()) + [cid]
                conn.execute(
                    f"UPDATE processing_channels SET {sets}, updated_at = CURRENT_TIMESTAMP WHERE id = ?",
                    vals,
                )
                conn.commit()
                audit(
                    conn,
                    event_type="config_change",
                    processing_channel_id=cid,
                    source_ip=self.client_address[0],
                    result="success",
                    detail=json.dumps(fields),
                )
                hot = None
                if "caption_policy" in fields or "captioning_enabled" in fields:
                    sock = control_sock_path(row["service_name"])
                    try:
                        if "caption_policy" in fields:
                            hot = send_caption_set(sock, policy=fields["caption_policy"])
                        else:
                            hot = send_caption_set(
                                sock, enabled=bool(int(fields["captioning_enabled"]))
                            )
                    except FileNotFoundError:
                        hot = {"ok": False, "error": "proc not running — will apply on next start"}
                    except Exception as exc:  # noqa: BLE001
                        hot = {"ok": False, "error": str(exc)}
                self._send(200, {"ok": True, "caption_hot": hot})
                return

            if path.startswith("/v1/egress/") and path.endswith("/config"):
                eid = int(path.split("/")[3])
                row = conn.execute(
                    "SELECT id FROM egress_channels WHERE id = ?", (eid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "egress channel not found"})
                    return
                allowed = {
                    "name",
                    "output_type",
                    "srt_mode",
                    "srt_remote_host",
                    "srt_remote_port",
                    "srt_listen_port",
                    "hls_mode",
                    "hls_push_url",
                    "target_bitrate_kbps",
                    "enabled",
                }
                fields = {k: body[k] for k in allowed if k in body}
                if not fields:
                    self._send(400, {"ok": False, "error": "no updatable fields"})
                    return
                if "output_type" in fields and fields["output_type"] not in ("srt", "hls"):
                    self._send(400, {"ok": False, "error": "output_type must be srt or hls"})
                    return
                if "srt_mode" in fields and fields["srt_mode"] not in (
                    None,
                    "",
                    "caller",
                    "listener",
                    "rendezvous",
                ):
                    self._send(400, {"ok": False, "error": "invalid srt_mode"})
                    return
                if "hls_mode" in fields and fields["hls_mode"] not in (
                    None,
                    "",
                    "origin_pull",
                    "push_put",
                ):
                    self._send(400, {"ok": False, "error": "invalid hls_mode"})
                    return
                # Normalize empty strings to NULL for optional host/url fields.
                for key in ("srt_remote_host", "hls_push_url", "srt_mode", "hls_mode"):
                    if key in fields and fields[key] == "":
                        fields[key] = None
                for key in ("srt_remote_port", "srt_listen_port", "target_bitrate_kbps"):
                    if key in fields and fields[key] in ("", None):
                        fields[key] = None
                    elif key in fields:
                        fields[key] = int(fields[key])
                if "enabled" in fields:
                    fields["enabled"] = 1 if fields["enabled"] in (True, 1, "1", "true", "on") else 0
                sets = ", ".join(f"{k} = ?" for k in fields)
                vals = list(fields.values()) + [eid]
                conn.execute(
                    f"UPDATE egress_channels SET {sets}, updated_at = CURRENT_TIMESTAMP WHERE id = ?",
                    vals,
                )
                conn.commit()
                audit(
                    conn,
                    event_type="config_change",
                    egress_channel_id=eid,
                    source_ip=self.client_address[0],
                    result="success",
                    detail=json.dumps(fields),
                )
                self._send(200, {"ok": True, "restart_hint": f"nexbreak-egress@{eid}"})
                return

            if path.startswith("/v1/processing/") and path.endswith("/captioning"):
                # Persist policy + signal running proc (may restart pipeline on mode flip).
                cid = int(path.split("/")[3])
                from nexbreak_caption_policy import (
                    enabled_from_policy,
                    normalize_policy,
                )

                if "policy" in body and body["policy"] is not None:
                    policy = normalize_policy(body["policy"])
                elif "enabled" in body:
                    policy = (
                        "auto"
                        if body["enabled"] in (True, 1, "1", "true", "on")
                        else "off"
                    )
                else:
                    self._send(400, {"ok": False, "error": "policy or enabled required"})
                    return
                enabled = enabled_from_policy(policy)
                row = conn.execute(
                    "SELECT * FROM processing_channels WHERE id = ?", (cid,)
                ).fetchone()
                if not row:
                    self._send(404, {"ok": False, "error": "not found"})
                    return
                conn.execute(
                    """
                    UPDATE processing_channels
                    SET caption_policy = ?, captioning_enabled = ?,
                        updated_at = CURRENT_TIMESTAMP
                    WHERE id = ?
                    """,
                    (policy, enabled, cid),
                )
                conn.commit()
                sock = control_sock_path(row["service_name"])
                try:
                    result = send_caption_set(sock, policy=policy)
                except FileNotFoundError:
                    result = {
                        "ok": True,
                        "desired": policy != "off",
                        "running": False,
                        "bypassed": policy == "off",
                        "policy": policy,
                        "note": "proc not running — persisted; applies on next start",
                    }
                except Exception as exc:  # noqa: BLE001
                    self._send(502, {"ok": False, "error": str(exc)})
                    return
                audit(
                    conn,
                    event_type="config_change",
                    processing_channel_id=cid,
                    source_ip=self.client_address[0],
                    result="success" if result.get("ok") else "failure",
                    detail=f"caption_policy={policy} hot={json.dumps(result)}",
                )
                self._send(
                    200,
                    {"ok": True, "enabled": enabled, "policy": policy, "runtime": result},
                )
                return

            self._send(404, {"ok": False, "error": f"unknown path {path}"})
        except (KeyError, ValueError, TypeError) as exc:
            self._send(400, {"ok": False, "error": str(exc)})
        except Exception as exc:  # noqa: BLE001
            log.exception("POST %s failed", path)
            self._send(500, {"ok": False, "error": str(exc)})
        finally:
            conn.close()

    def do_DELETE(self) -> None:  # noqa: N802
        path = urlparse(self.path).path.rstrip("/") or "/"
        conn = db()
        try:
            if path.startswith("/v1/captions/lexicon/"):
                eid = int(path.rsplit("/", 1)[-1])
                conn.execute("DELETE FROM caption_lexicon WHERE id = ?", (eid,))
                conn.commit()
                self._send(200, {"ok": True})
                return
            if path.startswith("/v1/captions/blacklist/"):
                eid = int(path.rsplit("/", 1)[-1])
                conn.execute("DELETE FROM caption_blacklist WHERE id = ?", (eid,))
                conn.commit()
                self._send(200, {"ok": True})
                return
            self._send(404, {"ok": False, "error": f"unknown path {path}"})
        finally:
            conn.close()


def main() -> int:
    global DB_PATH

    parser = argparse.ArgumentParser(description="NexBreak controller API")
    parser.add_argument("--db", default=None)
    parser.add_argument("--host", default=os.environ.get("NEXBREAK_API_HOST", "127.0.0.1"))
    parser.add_argument("--port", type=int, default=int(os.environ.get("NEXBREAK_API_PORT", "8787")))
    parser.add_argument("--init-db", action="store_true", help="create schema if missing")
    parser.add_argument("--seed", action="store_true", help="seed demo channels when empty")
    parser.add_argument(
        "--init-only",
        action="store_true",
        help="apply --init-db/--seed and exit (no HTTP listen)",
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )

    DB_PATH = args.db
    if DB_PATH is None:
        # Dev default: repo data/ when /var/lib/nexbreak is unavailable
        repo_data = Path(__file__).resolve().parent.parent / "data" / "nexbreak.sqlite"
        if not Path("/var/lib/nexbreak").exists():
            repo_data.parent.mkdir(parents=True, exist_ok=True)
            DB_PATH = str(repo_data)
            log.info("using dev DB %s", DB_PATH)

    need_init = args.init_db or args.init_only or (DB_PATH and not Path(DB_PATH).exists())
    conn = connect(DB_PATH)
    if need_init:
        init_schema(conn)
        log.info("schema applied to %s", DB_PATH)
    else:
        migrate(conn)
    if args.seed or need_init:
        seed_demo(conn)
    conn.close()

    if args.init_only:
        log.info("init-only complete")
        return 0

    httpd = ThreadingHTTPServer((args.host, args.port), Handler)
    log.info("listening on http://%s:%s  db=%s", args.host, args.port, DB_PATH or "default")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        log.info("shutting down")
    finally:
        httpd.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
