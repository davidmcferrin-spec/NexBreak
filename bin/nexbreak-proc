#!/usr/bin/env python3
"""
nexbreak-proc — processing channel (ingest → optional CC inject → SCTE-35 → local feed).

Pipeline:
  ffmpeg (RTSP/SRT/DeckLink → MPEG-TS stdout)
    [| nexbreak-cc-inject  when effective_mode=asr_insert]
    | tsp spliceinject → splicemonitor → UDP local feed

tsp runs --verbose; its stderr is parsed into structured splice state
(/run/nexbreak/splicemon/<svc>.json + journal): spliceinject lifecycle
(received/enqueued/injected/dropped) and splicemonitor JSON events.

Caption policy: off | auto | force_asr → effective off|preserve|asr_insert.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import signal
import socket
import socketserver
import sys
import threading
import time
from pathlib import Path
from subprocess import PIPE, Popen
from typing import Any, Optional

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_caption_policy import (  # noqa: E402
    cue_sock_path,
    effective_mode,
    enabled_from_policy,
    normalize_policy,
    probe_source_has_cc,
    vosk_ready,
)
from nexbreak_captions import CaptionSidecar  # noqa: E402
from nexbreak_db import (  # noqa: E402
    audit,
    cc_udp_endpoint_for,
    connect,
    control_sock_path,
    get_processing_by_service,
    migrate,
    preview_path_for,
    splice_udp_port_for,
)
from nexbreak_pipeline import (  # noqa: E402
    SPLICEMON_MARKER,
    clamp_splice_offset_ms,
    ffmpeg_ingest_argv,
    ffmpeg_preview_argv,
    output_bitrate_kbps,
    preview_feed_port_for,
    probe_mpegts_bitrate_kbps,
    probe_mpegts_has_video,
    require_bins,
    resolve_local_feed_host,
    scte35_command_payload,
    srt_latency_ms,
    tsp_splice_argv,
    write_bitrate_state,
    write_splicemon_state,
)
from nexbreak_verify import asr_dir, captions_dir, ensure_run_subdir  # noqa: E402

log = logging.getLogger("nexbreak-proc")
_stop = False
_event_id = 1
_channel: dict[str, Any] = {}
_splice_udp = 0
_procs: list[Popen] = []  # core: ffmpeg [, inject], tsp
_preview: Optional[Popen] = None
_preview_argv: list[str] = []
_preview_path = ""
_preview_started_at = 0.0
_preview_restart_at = 0.0
_preview_backoff_s = 3.0
_cc_watch: Optional[Popen] = None
_cc_watch_argv: list[str] = []
_cc_watch_restart_at = 0.0
_captions: Optional[CaptionSidecar] = None
_db_path: Optional[str] = None
_source_has_cc = False
_effective_mode = "off"
_pipeline_restart = False
_pipeline_restart_reason = ""
_next_probe_at = 0.0
_next_bitrate_at = 0.0
_next_feed_check_at = 0.0
_sensed_bitrate_kbps: Optional[int] = None
_feed_ok = True
_feed_fail_streak = 0
_pipeline_recycle_at = 0.0
_ingest_fault = False

# libsrt / ffmpeg lines that mean the ingest socket is wedged — recycle now.
_INGEST_FATAL_MARKERS = (
    "no room to store incoming packet",
    "connection broken",
    "connection timed out",
    "input/output error",
    "failed to receive packet",
    "srt_recvmsg",
    "broken pipe",
)

# In-chain splice visibility: spliceinject lifecycle counters (parsed from
# tsp --verbose stderr) + splicemonitor events (##splicemon## JSON lines).
_SPLICEMON_RECENT_MAX = 40
_splicemon_lock = threading.Lock()
_splicemon: dict[str, Any] = {}


def _splicemon_reset() -> None:
    """(Re)initialize splice-monitor state for a fresh tsp instance."""
    global _splicemon
    now = time.time()
    with _splicemon_lock:
        _splicemon = {
            "service_name": str(_channel.get("service_name") or ""),
            "tsp_started_at": now,
            # starting → live on first confirmed injection. spliceinject stays
            # completely silent until PTS lock, so "starting" that never turns
            # "live" after a Roll points at PTS lock / stuffing / PMT trouble.
            "engine": "starting",
            "udp_received": 0,
            "last_udp_received_at": None,
            "enqueued": 0,
            "last_enqueued_at": None,
            "injected": 0,
            "last_injected_at": None,
            "dropped": 0,
            "last_dropped_at": None,
            "last_dropped_line": None,
            "rejected": 0,
            "last_rejected_at": None,
            "last_rejected_line": None,
            "events_total": 0,
            "counts": {},
            "last_event": None,
            "recent": [],
            "updated_at": now,
        }
    _splicemon_flush()


def _splicemon_flush() -> None:
    with _splicemon_lock:
        svc = str(_splicemon.get("service_name") or "")
        if not svc:
            return
        snap = dict(_splicemon)
        snap["recent"] = list(_splicemon.get("recent") or [])
        snap["counts"] = dict(_splicemon.get("counts") or {})
        snap["updated_at"] = time.time()
    write_splicemon_state(svc, snap)


def _splicemon_snapshot(*, recent_limit: int = 10) -> dict[str, Any]:
    with _splicemon_lock:
        snap = dict(_splicemon)
        snap["recent"] = list(_splicemon.get("recent") or [])[:recent_limit]
        snap["counts"] = dict(_splicemon.get("counts") or {})
    return snap


def _splicemon_bump(counter: str, ts_key: str, **extra: Any) -> None:
    with _splicemon_lock:
        if not _splicemon:
            return
        _splicemon[counter] = int(_splicemon.get(counter) or 0) + 1
        _splicemon[ts_key] = time.time()
        _splicemon.update(extra)
    _splicemon_flush()


def _splicemon_event(obj: dict[str, Any]) -> None:
    """Record one splicemonitor JSON event (progress: pending/immediate/occurred/canceled)."""
    progress = str(obj.get("progress") or "event")
    entry = {
        "ts": time.time(),
        "progress": progress,
        "event_id": obj.get("event-id"),
        "event_type": obj.get("event-type"),
        "splice_pid": obj.get("splice-pid"),
        "time_to_event_ms": obj.get("time-to-event-ms"),
        "pre_roll_ms": obj.get("pre-roll-ms"),
        "status": obj.get("status"),
        "count": obj.get("count"),
    }
    with _splicemon_lock:
        if not _splicemon:
            return
        counts = _splicemon.setdefault("counts", {})
        counts[progress] = int(counts.get(progress) or 0) + 1
        _splicemon["events_total"] = int(_splicemon.get("events_total") or 0) + 1
        _splicemon["last_event"] = entry
        recent = _splicemon.setdefault("recent", [])
        recent.insert(0, entry)
        del recent[_SPLICEMON_RECENT_MAX:]
        _splicemon["engine"] = "live"
    _splicemon_flush()
    extra = ""
    if entry.get("pre_roll_ms") is not None:
        extra = f" pre_roll_ms={entry['pre_roll_ms']}"
    elif entry.get("time_to_event_ms") is not None:
        extra = f" time_to_event_ms={entry['time_to_event_ms']}"
    log.info(
        "splicemon: %s event_id=%s type=%s pid=%s%s",
        progress,
        entry.get("event_id"),
        entry.get("event_type") or "-",
        entry.get("splice_pid"),
        extra,
    )


def _tsp_log_reader(stream: Any) -> None:
    """
    Drain tsp stderr: parse splicemonitor ##splicemon## JSON events and
    spliceinject lifecycle lines into _splicemon; forward the rest to the log.
    Runs as a daemon thread per tsp instance; exits on pipe EOF.
    """
    try:
        for raw in iter(stream.readline, b""):
            line = raw.decode("utf-8", errors="replace").rstrip()
            if not line:
                continue
            if SPLICEMON_MARKER in line:
                blob = line[line.find(SPLICEMON_MARKER) + len(SPLICEMON_MARKER):].strip()
                try:
                    obj = json.loads(blob)
                except json.JSONDecodeError:
                    log.warning("splicemon parse failed: %.200s", blob)
                    continue
                if isinstance(obj, dict):
                    _splicemon_event(obj)
                continue
            if "spliceinject:" in line:
                low = line.lower()
                if "received message" in low:
                    _splicemon_bump("udp_received", "last_udp_received_at")
                elif "enqueuing" in low:
                    _splicemon_bump("enqueued", "last_enqueued_at")
                elif "injecting" in low:
                    _splicemon_bump(
                        "injected", "last_injected_at", engine="live"
                    )
                elif "dropping" in low:
                    _splicemon_bump(
                        "dropped", "last_dropped_at", last_dropped_line=line[:240]
                    )
                elif "error" in low:
                    # Command parse/validation rejects (bad XML, bad section…)
                    _splicemon_bump(
                        "rejected", "last_rejected_at", last_rejected_line=line[:240]
                    )
                if "error" in low:
                    log.error("tsp: %s", line)
                else:
                    log.info("tsp: %s", line)
                continue
            low = line.lower()
            if "error" in low:
                log.error("tsp: %s", line)
            elif "warning" in low:
                log.warning("tsp: %s", line)
            else:
                log.info("tsp: %s", line)
    except Exception as exc:  # noqa: BLE001
        log.debug("tsp log reader ended: %s", exc)
    finally:
        try:
            stream.close()
        except Exception:
            pass


def _start_tsp_log_reader(tsp_proc: Popen) -> None:
    if tsp_proc.stderr is None:
        return
    threading.Thread(
        target=_tsp_log_reader,
        args=(tsp_proc.stderr,),
        name="tsp-log",
        daemon=True,
    ).start()


def _handle_signal(signum, _frame):
    global _stop
    log.info("signal %s — shutting down", signum)
    _stop = True
    # Fast-path: SIGTERM children now so systemd stop isn't blocked on SRT/ffmpeg.
    for p in list(reversed(_procs)):
        if p.poll() is None:
            try:
                p.terminate()
            except Exception:
                pass
    for side in (_preview, _cc_watch):
        if side is not None and side.poll() is None:
            try:
                side.terminate()
            except Exception:
                pass


def _policy() -> str:
    return normalize_policy(
        _channel.get("caption_policy"),
        captioning_enabled=_channel.get("captioning_enabled"),
    )


def _refresh_effective_mode() -> str:
    global _effective_mode
    _effective_mode = effective_mode(
        _policy(), _source_has_cc, asr_available=vosk_ready()
    )
    return _effective_mode


def _stop_media(*, stop_captions: bool = False) -> None:
    """Stop ffmpeg/inject/tsp + preview/cc-watch. Optionally stop ASR worker."""
    global _preview, _cc_watch, _captions, _preview_argv, _cc_watch_argv
    global _preview_path, _preview_started_at
    if stop_captions and _captions is not None:
        _captions.shutdown()
        _captions = None
    elif _captions is not None:
        _captions.set_asr_desired(False)

    for p in reversed(_procs):
        if p.poll() is None:
            try:
                p.terminate()
            except Exception:
                pass
    for side in (_preview, _cc_watch):
        if side is not None and side.poll() is None:
            try:
                side.terminate()
            except Exception:
                pass
    deadline = time.time() + 1.5
    sides = [p for p in (_preview, _cc_watch) if p is not None]
    for p in list(reversed(_procs)) + sides:
        if p.poll() is None:
            remaining = max(0.05, deadline - time.time())
            try:
                p.wait(timeout=remaining)
            except Exception:
                try:
                    p.kill()
                except Exception:
                    pass
    _procs.clear()
    _preview = None
    _preview_argv = []
    _preview_path = ""
    _preview_started_at = 0.0
    _cc_watch = None
    _cc_watch_argv = []


def _kill_pipeline() -> None:
    _stop_media(stop_captions=True)


def _start_captions(channel: dict[str, Any]) -> None:
    global _captions
    if _captions is None:
        _captions = CaptionSidecar(channel, db_path=_db_path)
    _captions.set_policy(_policy())
    want_asr = _effective_mode == "asr_insert"
    _captions.set_asr_desired(want_asr)
    if not want_asr:
        log.info(
            "ASR worker not required (policy=%s effective=%s source_cc=%s)",
            _policy(),
            _effective_mode,
            _source_has_cc,
        )


def _ensure_runtime_dirs() -> None:
    """Durable + run-dir state paths used by this unit (avoid EROFS surprises)."""
    try:
        captions_dir(create=True)
    except OSError as exc:
        log.warning("captions dir: %s", exc)
    try:
        asr_dir(create=True)
    except OSError as exc:
        log.warning("asr dir: %s", exc)
    for name in ("bitrate", "splicemon"):
        try:
            ensure_run_subdir(name)
        except OSError as exc:
            log.warning("run/%s: %s", name, exc)


def _request_pipeline_restart(reason: str) -> None:
    global _pipeline_restart, _pipeline_restart_reason
    _pipeline_restart = True
    _pipeline_restart_reason = reason
    log.warning("pipeline restart queued: %s", reason)


def _ingest_stderr_watch(proc: Popen, stream) -> None:
    """Recycle when libsrt reports receive-buffer overflow / dead peer."""
    global _ingest_fault
    try:
        for raw in stream:
            if _stop:
                break
            line = raw.decode("utf-8", errors="replace").strip()
            if not line:
                continue
            low = line.lower()
            if any(m in low for m in _INGEST_FATAL_MARKERS):
                log.warning("ingest fault — recycling: %s", line[:220])
                _ingest_fault = True
                try:
                    proc.terminate()
                except Exception:
                    pass
                break
    except Exception as exc:  # noqa: BLE001
        log.debug("ingest stderr watch ended: %s", exc)


def _start_ingest_log_reader(ff: Popen) -> None:
    if ff.stderr is None:
        return
    t = threading.Thread(
        target=_ingest_stderr_watch,
        args=(ff, ff.stderr),
        name="ingest-stderr",
        daemon=True,
    )
    t.start()


def _mediamtx_path_ready(name: str) -> bool:
    """True when MediaMTX has a ready publisher on path `name`."""
    if not name:
        return False
    base = (os.environ.get("NEXBREAK_MEDIAMTX_API") or "http://127.0.0.1:9997").rstrip("/")
    try:
        import urllib.request

        with urllib.request.urlopen(f"{base}/v3/paths/list", timeout=1.0) as resp:
            data = json.loads(resp.read().decode())
        for item in data.get("items") or []:
            if item.get("name") == name and item.get("ready"):
                return True
    except Exception:
        return False
    return False


def _start_preview(channel: dict[str, Any], ffmpeg: str) -> None:
    global _preview, _preview_argv, _preview_path, _preview_started_at
    if not int(channel.get("preview_enabled") if channel.get("preview_enabled") is not None else 1):
        log.info("preview disabled for this channel")
        return
    path = preview_path_for(channel)
    _preview_path = path
    preview_port = preview_feed_port_for(channel)
    offset_ms = clamp_splice_offset_ms(channel.get("splice_insertion_delay_ms"))
    _preview_argv = ffmpeg_preview_argv(
        ffmpeg=ffmpeg,
        feed_host=channel["local_feed_host"] or "127.0.0.1",
        feed_port=preview_port,
        preview_path=path,
    )
    if offset_ms < 0:
        log.info(
            "preview: reading pretap (pre-timeshift) port %s — offset=%sms",
            preview_port,
            offset_ms,
        )
    log.info("preview: %s", " ".join(_preview_argv))
    # Wait for local feed to carry PAT/PMT + a keyframe before attaching.
    # Negative offset: timeshift fills for |offset| ms before feed output, but
    # pretap is immediate — still allow PAT/PMT settle time.
    time.sleep(2.5)
    _preview = Popen(_preview_argv)
    _preview_started_at = time.time()


def _ensure_preview() -> None:
    global _preview, _preview_restart_at, _preview_started_at, _preview_backoff_s
    if not _preview_argv:
        return
    now = time.time()
    # Empty/wedged local feed: do not thrash-restart the publisher (was every ~30s).
    if not _feed_ok:
        if _preview is not None and _preview.poll() is None:
            return
        if now < _preview_restart_at:
            return
        _preview_restart_at = now + max(15.0, _preview_backoff_s)
        log.info("preview waiting — local feed has no video yet")
        return
    if _preview is not None and _preview.poll() is None:
        # Process can sit forever mid-GOP / starved without ever publishing.
        if _mediamtx_path_ready(_preview_path):
            _preview_backoff_s = 3.0
            return
        if now - _preview_started_at < 25.0:
            return
        log.warning(
            "preview alive but MediaMTX path %s not ready — recycling publisher",
            _preview_path or "?",
        )
        try:
            _preview.terminate()
            _preview.wait(timeout=2.0)
        except Exception:
            try:
                _preview.kill()
            except Exception:
                pass
        _preview = None
        _preview_restart_at = 0.0
    if now < _preview_restart_at:
        return
    _preview_restart_at = now + _preview_backoff_s
    _preview_backoff_s = min(60.0, _preview_backoff_s * 1.5)
    code = _preview.returncode if _preview is not None else "n/a"
    log.warning("preview publisher down (code=%s) — restarting", code)
    _preview = Popen(_preview_argv)
    _preview_started_at = time.time()


def _start_cc_watch(channel: dict[str, Any]) -> None:
    global _cc_watch, _cc_watch_argv
    if not int(channel.get("preview_enabled") if channel.get("preview_enabled") is not None else 1):
        return
    watch = Path(__file__).resolve().parent / "nexbreak-cc-watch"
    if not watch.is_file():
        log.warning("nexbreak-cc-watch missing — CC overlay idle")
        return
    path = preview_path_for(channel)
    _cc_watch_argv = [
        sys.executable,
        str(watch),
        "--preview-path",
        path,
        "--feed-host",
        channel["local_feed_host"] or "127.0.0.1",
        "--feed-port",
        str(int(channel["local_feed_port"])),
    ]
    log.info("cc-watch: %s", " ".join(_cc_watch_argv))
    _cc_watch = Popen(_cc_watch_argv)


def _ensure_cc_watch() -> None:
    global _cc_watch, _cc_watch_restart_at
    if not _cc_watch_argv:
        return
    if _cc_watch is not None and _cc_watch.poll() is None:
        return
    now = time.time()
    if now < _cc_watch_restart_at:
        return
    _cc_watch_restart_at = now + 5.0
    code = _cc_watch.returncode if _cc_watch is not None else "n/a"
    log.warning("cc-watch down (code=%s) — restarting", code)
    _cc_watch = Popen(_cc_watch_argv)


def _inject_script() -> Path:
    return Path(__file__).resolve().parent / "nexbreak-cc-inject"


def _start_pipeline(channel: dict[str, Any], splice_udp: int) -> None:
    global _source_has_cc, _next_probe_at, _feed_ok, _feed_fail_streak
    global _ingest_fault, _next_feed_check_at, _preview_backoff_s
    bins = require_bins("ffmpeg", "tsp")
    feed_host = channel["local_feed_host"] or "127.0.0.1"
    feed_port = int(channel["local_feed_port"])
    feed_dest = resolve_local_feed_host(feed_host)

    _ensure_runtime_dirs()
    _ingest_fault = False
    _feed_ok = True
    _feed_fail_streak = 0
    _preview_backoff_s = 3.0
    _next_feed_check_at = time.time() + 12.0

    _source_has_cc = probe_source_has_cc(channel)
    _next_probe_at = time.time() + 30.0
    mode = _refresh_effective_mode()
    log.info(
        "caption policy=%s source_has_cc=%s effective=%s srt_latency_ms=%s",
        _policy(),
        _source_has_cc,
        mode,
        srt_latency_ms(),
    )
    if feed_dest != feed_host:
        log.info(
            "local feed fan-out: %s:%s → multicast %s:%s "
            "(preview/egress/cc-watch each get a full copy)",
            feed_host,
            feed_port,
            feed_dest,
            feed_port,
        )

    ff_argv = ffmpeg_ingest_argv(channel, bins["ffmpeg"])
    tsp_argv = tsp_splice_argv(
        channel,
        bins["tsp"],
        splice_udp_port=splice_udp,
        feed_host=feed_host,
        feed_port=feed_port,
    )
    log.info("ffmpeg: %s", " ".join(ff_argv))
    log.info("tsp: %s", " ".join(tsp_argv))

    _splicemon_reset()

    # Capture stderr so we can recycle on libsrt receive-buffer overflow.
    ff = Popen(ff_argv, stdout=PIPE, stderr=PIPE)
    _start_ingest_log_reader(ff)
    if mode == "asr_insert":
        inject_path = _inject_script()
        if not inject_path.is_file():
            raise RuntimeError(f"missing {inject_path}")
        cue = cue_sock_path(str(channel["service_name"]))
        cc_udp = cc_udp_endpoint_for(channel)
        inj_argv = [
            sys.executable,
            str(inject_path),
            "--cue-sock",
            cue,
            "--cc-udp",
            cc_udp,
            "--bitrate",
            f"{int(channel.get('target_bitrate_kbps') or 14000)}k",
        ]
        log.info("cc-inject (LCE): %s", " ".join(inj_argv))
        inj = Popen(inj_argv, stdin=ff.stdout, stdout=PIPE, stderr=None)
        if ff.stdout is not None:
            ff.stdout.close()
        tsp = Popen(tsp_argv, stdin=inj.stdout, stderr=PIPE)
        if inj.stdout is not None:
            inj.stdout.close()
        _procs.extend([ff, inj, tsp])
    else:
        tsp = Popen(tsp_argv, stdin=ff.stdout, stderr=PIPE)
        if ff.stdout is not None:
            ff.stdout.close()
        _procs.extend([ff, tsp])
    # Structured splice visibility: parse spliceinject lifecycle + splicemonitor
    # JSON from tsp --verbose stderr (otherwise splice failures are silent).
    _start_tsp_log_reader(tsp)

    try:
        _start_preview(channel, bins["ffmpeg"])
    except Exception as exc:  # noqa: BLE001
        log.warning("preview publisher failed to start (non-fatal): %s", exc)
    try:
        _start_cc_watch(channel)
    except Exception as exc:  # noqa: BLE001
        log.warning("cc-watch failed to start (non-fatal): %s", exc)
    try:
        _start_captions(channel)
    except Exception as exc:  # noqa: BLE001
        log.warning("caption sidecar failed to start (non-fatal): %s", exc)


def _restart_pipeline(channel: dict[str, Any], splice_udp: int) -> None:
    reason = _pipeline_restart_reason or "manual"
    log.info("restarting media pipeline (%s)", reason)
    _stop_media(stop_captions=False)
    time.sleep(0.4)
    _start_pipeline(channel, splice_udp)


def _tick_bitrate_sense() -> None:
    """Probe local feed bitrate; persist for UI and keep target_bitrate = sensed+10."""
    global _sensed_bitrate_kbps, _next_bitrate_at, _channel
    if not _channel:
        return
    now = time.time()
    if now < _next_bitrate_at:
        return
    _next_bitrate_at = now + 15.0
    host = _channel.get("local_feed_host") or "127.0.0.1"
    port = int(_channel.get("local_feed_port") or 0)
    if port <= 0:
        return
    sensed = probe_mpegts_bitrate_kbps(host, port, timeout=6.0)
    if not sensed:
        return
    out = output_bitrate_kbps(sensed)
    prev = _sensed_bitrate_kbps
    _sensed_bitrate_kbps = sensed
    write_bitrate_state(
        str(_channel.get("service_name") or ""),
        sensed_kbps=sensed,
        output_kbps=out,
    )
    if prev != sensed:
        log.info("sensed bitrate %s kbps → output target %s kbps (+10)", sensed, out)
    # Persist so LCE/cc-inject and Channels UI share the same target.
    if out and int(_channel.get("target_bitrate_kbps") or 0) != int(out):
        _channel["target_bitrate_kbps"] = int(out)
        if _db_path:
            try:
                conn = connect(_db_path)
                try:
                    migrate(conn)
                    conn.execute(
                        """
                        UPDATE processing_channels
                        SET target_bitrate_kbps = ?, updated_at = CURRENT_TIMESTAMP
                        WHERE id = ?
                        """,
                        (int(out), int(_channel["id"])),
                    )
                    # Keep egress target in sync for the routed outputs (display/CDN hint).
                    conn.execute(
                        """
                        UPDATE egress_channels
                        SET target_bitrate_kbps = ?, updated_at = CURRENT_TIMESTAMP
                        WHERE id IN (
                          SELECT egress_channel_id FROM routing_assignments
                          WHERE processing_channel_id = ?
                        )
                        """,
                        (int(out), int(_channel["id"])),
                    )
                    conn.commit()
                finally:
                    conn.close()
            except Exception as exc:  # noqa: BLE001
                log.debug("bitrate persist failed: %s", exc)


def _tick_feed_health() -> None:
    """
    Detect wedged local feed while children still look 'alive'.

    Two consecutive misses (~20s) schedule an in-process pipeline recycle —
    the failure mode we saw on sctetest (SRT OK, UDP empty, preview thrash).
    """
    global _feed_ok, _feed_fail_streak, _next_feed_check_at
    if not _channel or not _procs:
        return
    now = time.time()
    if now < _next_feed_check_at:
        return
    # Skip checks for a grace window after pipeline start / recycle.
    _next_feed_check_at = now + 10.0
    host = _channel.get("local_feed_host") or "127.0.0.1"
    port = int(_channel.get("local_feed_port") or 0)
    if port <= 0:
        return
    ok = probe_mpegts_has_video(host, port, timeout=4.5)
    if ok:
        if not _feed_ok:
            log.info("local feed video restored")
        _feed_ok = True
        _feed_fail_streak = 0
        return
    _feed_fail_streak += 1
    _feed_ok = False
    log.warning(
        "local feed has no video (streak=%s) — preview will back off",
        _feed_fail_streak,
    )
    if _feed_fail_streak >= 2 and now >= _pipeline_recycle_at:
        _request_pipeline_restart("local feed silent (no video)")


def _watch_pipeline() -> Optional[int]:
    """Return exit code if a core child died; None if still healthy."""
    global _source_has_cc, _next_probe_at, _ingest_fault
    if _ingest_fault:
        _ingest_fault = False
        return -1  # treated as recycle signal by main loop
    for p in _procs:
        code = p.poll()
        if code is not None:
            return code
    _tick_feed_health()
    _ensure_preview()
    _ensure_cc_watch()
    if _captions is not None:
        _captions.tick()
    _tick_bitrate_sense()

    now = time.time()
    if now >= _next_probe_at and _channel:
        _next_probe_at = now + 30.0
        if _policy() == "auto":
            prev = _source_has_cc
            try:
                _source_has_cc = probe_source_has_cc(_channel, timeout=5.0)
            except Exception as exc:  # noqa: BLE001
                log.warning("CC re-probe failed: %s", exc)
            else:
                new_mode = effective_mode(
                    "auto", _source_has_cc, asr_available=vosk_ready()
                )
                if new_mode != _effective_mode or prev != _source_has_cc:
                    log.info(
                        "CC probe changed source_has_cc %s→%s — scheduling restart",
                        prev,
                        _source_has_cc,
                    )
                    _request_pipeline_restart(
                        f"CC probe source_has_cc {prev}→{_source_has_cc}"
                    )
    return None


def _send_to_spliceinject(payload: bytes) -> None:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.sendto(payload, ("127.0.0.1", _splice_udp))
    finally:
        sock.close()


def _splice_send_plan() -> tuple[int, float]:
    """(count, gap_s) for repeated splice command sends.

    Default is a single send: one trigger = one splice_insert in the stream.
    The in-chain splicemonitor confirms every injection losslessly, so repeat
    copies are no longer needed as delivery insurance — and while duplicates
    (same event_id) are idempotent for compliant splicers, sloppier downstream
    gear can treat each "immediate" copy as a fresh trigger. Set
    NEXBREAK_SPLICE_SEND_COUNT>1 to restore repeats if a lossy path needs them.
    """
    try:
        count = max(1, int(os.environ.get("NEXBREAK_SPLICE_SEND_COUNT", "1")))
    except ValueError:
        count = 1
    try:
        gap_ms = max(0, int(os.environ.get("NEXBREAK_SPLICE_SEND_GAP_MS", "150")))
    except ValueError:
        gap_ms = 150
    return count, gap_ms / 1000.0


def _send_splice_payload(payload: bytes) -> int:
    count, gap_s = _splice_send_plan()
    for i in range(count):
        if i and gap_s > 0:
            time.sleep(gap_s)
        _send_to_spliceinject(payload)
    return count


def _apply_splice(
    splice_type: str,
    hex_payload: Optional[str],
    event_id: Optional[int],
    *,
    skip_delay: bool = False,
    auto_return: bool = False,
    break_duration_sec: Optional[float] = None,
    use_channel_delay: bool = True,
) -> dict[str, Any]:
    global _event_id
    eid = int(event_id) if event_id is not None else _event_id
    if event_id is None:
        _event_id += 1

    offset_ms = clamp_splice_offset_ms(_channel.get("splice_insertion_delay_ms"))
    if not use_channel_delay or splice_type == "splice_cancel":
        offset_ms = 0
    # Positive offset = hold the trigger; negative = video already held in tsp.
    delay_ms = max(0, offset_ms)
    if not skip_delay and delay_ms > 0:
        log.info("splice %s event_id=%s — waiting %s ms", splice_type, eid, delay_ms)
        end = time.time() + delay_ms / 1000.0
        while not _stop and time.time() < end:
            time.sleep(min(0.1, end - time.time()))
        if _stop:
            return {"ok": False, "error": "aborted"}

    kind, payload = scte35_command_payload(
        splice_type=splice_type,
        event_id=eid,
        hex_payload=hex_payload,
        auto_return=bool(auto_return),
        break_duration_sec=break_duration_sec,
    )
    sends = _send_splice_payload(payload)
    extra = ""
    if auto_return and break_duration_sec:
        extra = f" auto_return={break_duration_sec}s"
    if offset_ms < 0:
        offset_note = f" offset={offset_ms}ms(video-hold)"
    elif offset_ms > 0:
        offset_note = f" offset=+{offset_ms}ms(trigger-hold)"
    else:
        offset_note = " offset=0ms"
    # payload:<hex> suffix is machine-readable — the Verify page decodes it
    # for the Sent-side payload inspector; the Audit page strips it.
    detail = (
        f"{kind} {len(payload)} bytes event_id={eid}{extra}{offset_note} "
        f"→ udp/{_splice_udp} x{sends} payload:{payload.hex()}"
    )

    log.info("injected %s (%s)", splice_type, detail)
    return {
        "ok": True,
        "event_id": eid,
        "detail": detail,
        "delay_ms": delay_ms,
        "offset_ms": offset_ms,
    }


def _caption_runtime() -> dict[str, Any]:
    cap = (
        _captions.status()
        if _captions
        else {"desired": False, "running": False, "bypassed": True}
    )
    # Always attach latest ASR snapshot (even if sidecar briefly down).
    if "asr" not in cap and _channel:
        try:
            from nexbreak_captions import read_asr_live

            cap["asr"] = read_asr_live(str(_channel.get("service_name") or "")) or {}
        except Exception:
            cap["asr"] = {}
    return {
        "ok": True,
        **cap,
        "policy": _policy(),
        "source_has_cc": _source_has_cc,
        "effective_mode": _effective_mode,
        "inject_active": _effective_mode == "asr_insert",
    }


class _ControlHandler(socketserver.StreamRequestHandler):
    def handle(self) -> None:
        global _pipeline_restart, _channel, _captions
        try:
            line = self.rfile.readline()
            if not line:
                return
            req = json.loads(line.decode("utf-8"))
        except Exception as exc:  # noqa: BLE001
            self._reply({"ok": False, "error": f"bad request: {exc}"})
            return

        cmd = req.get("cmd")
        if cmd == "ping":
            self._reply({"ok": True, "service": _channel.get("service_name")})
            return
        if cmd == "status":
            self._reply(
                {
                    "ok": True,
                    "channel_id": _channel.get("id"),
                    "name": _channel.get("name"),
                    "splice_udp_port": _splice_udp,
                    "feed": f"{_channel.get('local_feed_host')}:{_channel.get('local_feed_port')}",
                    "preview_path": preview_path_for(_channel) if _channel else None,
                    "preview_alive": _preview is not None and _preview.poll() is None,
                    "pipeline_alive": all(p.poll() is None for p in _procs) if _procs else False,
                    "feed_ok": bool(_feed_ok),
                    "feed_fail_streak": int(_feed_fail_streak),
                    "captions": _caption_runtime(),
                    "splice_monitor": _splicemon_snapshot(),
                }
            )
            return
        if cmd == "caption_set":
            if _captions is None:
                _captions = CaptionSidecar(_channel, db_path=_db_path)
            old_mode = _effective_mode
            if "policy" in req and req["policy"] is not None:
                pol = normalize_policy(req["policy"])
            elif "enabled" in req:
                pol = "auto" if bool(req.get("enabled")) else "off"
            else:
                self._reply({"ok": False, "error": "policy or enabled required"})
                return
            _channel["caption_policy"] = pol
            _channel["captioning_enabled"] = enabled_from_policy(pol)
            _captions.set_policy(pol)
            new_mode = _refresh_effective_mode()
            if new_mode != old_mode:
                _request_pipeline_restart(f"caption mode {old_mode}→{new_mode}")
                log.info("caption mode %s→%s — pipeline restart queued", old_mode, new_mode)
            else:
                _captions.set_asr_desired(new_mode == "asr_insert")
            self._reply(_caption_runtime())
            return
        if cmd == "caption_status":
            self._reply(_caption_runtime())
            return
        if cmd == "config_set":
            # Hot-apply fields that can change without a full systemd restart.
            # Negative (or changed-negative) splice offset rebuilds the tsp
            # chain (timeshift / pretap); positive-only changes stay live.
            if "splice_insertion_delay_ms" not in req:
                self._reply(
                    {"ok": False, "error": "splice_insertion_delay_ms required"}
                )
                return
            old = clamp_splice_offset_ms(_channel.get("splice_insertion_delay_ms"))
            new = clamp_splice_offset_ms(req.get("splice_insertion_delay_ms"))
            _channel["splice_insertion_delay_ms"] = new
            restart = old < 0 or new < 0
            if restart and old != new:
                _request_pipeline_restart(f"splice offset {old}→{new}")
                log.info(
                    "splice offset %sms→%sms — pipeline restart queued "
                    "(video-hold / pretap)",
                    old,
                    new,
                )
            else:
                log.info("splice offset hot-set to %sms (no pipeline restart)", new)
            self._reply(
                {
                    "ok": True,
                    "splice_insertion_delay_ms": new,
                    "pipeline_restart": bool(restart and old != new),
                }
            )
            return
        if cmd == "splice":
            try:
                result = _apply_splice(
                    splice_type=req.get("splice_type") or "splice_start_immediate",
                    hex_payload=req.get("hex_payload"),
                    event_id=req.get("event_id"),
                    auto_return=bool(req.get("auto_return")),
                    break_duration_sec=(
                        float(req["break_duration_sec"])
                        if req.get("break_duration_sec") is not None
                        else None
                    ),
                    use_channel_delay=bool(req.get("use_channel_delay", True)),
                )
                self._reply(result)
            except Exception as exc:  # noqa: BLE001
                log.exception("splice failed")
                self._reply({"ok": False, "error": str(exc)})
            return
        self._reply({"ok": False, "error": f"unknown cmd {cmd}"})

    def _reply(self, obj: dict[str, Any]) -> None:
        self.wfile.write((json.dumps(obj) + "\n").encode("utf-8"))


class _ThreadingUnixServer(socketserver.ThreadingMixIn, socketserver.UnixStreamServer):
    daemon_threads = True
    allow_reuse_address = True


def _start_control_server(sock_path: str) -> _ThreadingUnixServer:
    Path(sock_path).parent.mkdir(parents=True, exist_ok=True)
    if os.path.exists(sock_path):
        os.unlink(sock_path)
    server = _ThreadingUnixServer(sock_path, _ControlHandler)
    os.chmod(sock_path, 0o660)
    t = threading.Thread(target=server.serve_forever, name="proc-control", daemon=True)
    t.start()
    log.info("control socket %s", sock_path)
    return server


def main() -> int:
    global _channel, _splice_udp, _stop, _db_path, _pipeline_restart
    global _pipeline_restart_reason, _pipeline_recycle_at

    parser = argparse.ArgumentParser(description="NexBreak processing channel")
    parser.add_argument("--service-name", required=True)
    parser.add_argument("--db", default=None)
    parser.add_argument("--once", action="store_true", help="load config / print plan / exit")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print ffmpeg/tsp argv and exit (no subprocesses)",
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle_signal)
    signal.signal(signal.SIGTERM, _handle_signal)

    _db_path = args.db
    conn = connect(args.db)
    try:
        migrate(conn)
        channel = get_processing_by_service(conn, args.service_name)
        if channel is None:
            log.error("no processing_channels row for service_name=%r", args.service_name)
            return 1
        if not channel["enabled"]:
            log.warning("channel %s disabled — exiting", channel["name"])
            return 0

        _channel = channel
        _splice_udp = splice_udp_port_for(channel)
        sock_path = control_sock_path(args.service_name)
        ppath = preview_path_for(channel)

        log.info(
            "plan: %s type=%s delay_ms=%s feed=%s:%s splice_udp=%s preview=%s "
            "caption_policy=%s sock=%s",
            channel["name"],
            channel["input_type"],
            channel["splice_insertion_delay_ms"],
            channel["local_feed_host"],
            channel["local_feed_port"],
            _splice_udp,
            ppath
            if int(channel.get("preview_enabled") if channel.get("preview_enabled") is not None else 1)
            else "off",
            normalize_policy(
                channel.get("caption_policy"),
                captioning_enabled=channel.get("captioning_enabled"),
            ),
            sock_path,
        )

        if args.once or args.dry_run:
            bins = require_bins("ffmpeg", "tsp")
            print("FFMPEG", " ".join(ffmpeg_ingest_argv(channel, bins["ffmpeg"])))
            print(
                "TSP",
                " ".join(
                    tsp_splice_argv(
                        channel,
                        bins["tsp"],
                        splice_udp_port=_splice_udp,
                        feed_host=channel["local_feed_host"],
                        feed_port=int(channel["local_feed_port"]),
                    )
                ),
            )
            if int(channel.get("preview_enabled") if channel.get("preview_enabled") is not None else 1):
                print(
                    "PREVIEW",
                    " ".join(
                        ffmpeg_preview_argv(
                            ffmpeg=bins["ffmpeg"],
                            feed_host=channel["local_feed_host"] or "127.0.0.1",
                            feed_port=preview_feed_port_for(channel),
                            preview_path=ppath,
                        )
                    ),
                )
            return 0

        server = _start_control_server(sock_path)
        try:
            _ensure_runtime_dirs()
            _start_pipeline(channel, _splice_udp)
        except ValueError as exc:
            log.error("failed to start pipeline (config): %s", exc)
            audit(
                conn,
                event_type="service_crash",
                processing_channel_id=channel["id"],
                result="failure",
                detail=f"config: {exc}",
            )
            log.error(
                "holding idle (systemd will not restart-loop) — "
                "fix input settings in Channels, then: systemctl restart nexbreak-proc@%s",
                args.service_name,
            )
            while not _stop:
                time.sleep(1.0)
            server.shutdown()
            try:
                os.unlink(sock_path)
            except OSError:
                pass
            return 0
        except Exception as exc:  # noqa: BLE001
            log.exception("failed to start pipeline: %s", exc)
            audit(
                conn,
                event_type="service_crash",
                processing_channel_id=channel["id"],
                result="failure",
                detail=str(exc),
            )
            server.shutdown()
            return 1

        audit(
            conn,
            event_type="service_start",
            processing_channel_id=channel["id"],
            detail=(
                f"nexbreak-proc@{args.service_name} pipeline up; "
                f"feed {channel['local_feed_host']}:{channel['local_feed_port']}; "
                f"splice_udp {_splice_udp}; preview {ppath}; "
                f"caption_policy={_policy()} effective={_effective_mode}"
            ),
        )

        rc = 0
        recycle_backoff = 2.0
        while not _stop:
            if _pipeline_restart:
                reason = _pipeline_restart_reason or "queued"
                _pipeline_restart = False
                _pipeline_restart_reason = ""
                now = time.time()
                if now < _pipeline_recycle_at:
                    time.sleep(0.2)
                    _pipeline_restart = True
                    _pipeline_restart_reason = reason
                    continue
                try:
                    _restart_pipeline(_channel, _splice_udp)
                    _pipeline_recycle_at = time.time() + max(8.0, recycle_backoff)
                    recycle_backoff = min(60.0, recycle_backoff * 1.4)
                    audit(
                        conn,
                        event_type="config_change",
                        processing_channel_id=channel["id"],
                        detail=(
                            f"pipeline restart effective_mode={_effective_mode} "
                            f"reason={reason}"
                        ),
                    )
                except Exception as exc:  # noqa: BLE001
                    log.exception("pipeline restart failed: %s", exc)
                    rc = 1
                    break
                continue
            dead = _watch_pipeline()
            if dead is not None:
                # In-process recycle — keep control socket / ASR sidecar policy
                # instead of exiting and waiting on systemd Restart=.
                log.error(
                    "pipeline child exited code=%s — recycling in-process",
                    dead,
                )
                audit(
                    conn,
                    event_type="service_crash",
                    processing_channel_id=channel["id"],
                    result="failure",
                    detail=f"pipeline child exited {dead} — in-process recycle",
                )
                _request_pipeline_restart(f"child exit {dead}")
                continue
            # Healthy stretch: ease recycle backoff.
            if _feed_ok and recycle_backoff > 2.0:
                recycle_backoff = max(2.0, recycle_backoff * 0.95)
            time.sleep(0.5)

        _kill_pipeline()
        server.shutdown()
        try:
            os.unlink(sock_path)
        except OSError:
            pass

        audit(
            conn,
            event_type="service_stop",
            processing_channel_id=channel["id"],
            detail=f"nexbreak-proc@{args.service_name} stopped",
        )
        return rc
    finally:
        conn.close()


if __name__ == "__main__":
    raise SystemExit(main())
