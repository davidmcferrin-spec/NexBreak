#!/usr/bin/env python3
"""
nexbreak-egress — local feed → SRT (v1) / HLS (later).

Reads the MPEG-TS UDP feed currently assigned by routing_assignments
(processing local_feed_host:port) and pushes SRT via ffmpeg+libsrt.
"""

from __future__ import annotations

import argparse
import logging
import signal
import sys
import time
from pathlib import Path
from subprocess import Popen
from typing import Any, Optional

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_db import audit, connect, get_egress_by_service, row_to_dict  # noqa: E402
from nexbreak_pipeline import (  # noqa: E402
    ffmpeg_egress_argv,
    require_bins,
    resolve_local_feed_host,
)

log = logging.getLogger("nexbreak-egress")
_stop = False
_proc: Optional[Popen] = None


def _handle_signal(signum, _frame):
    global _stop
    log.info("signal %s — shutting down", signum)
    _stop = True


def _routed_source(conn, egress_id: int) -> Optional[dict[str, Any]]:
    cur = conn.execute(
        """
        SELECT pc.*
        FROM routing_assignments ra
        JOIN processing_channels pc ON pc.id = ra.processing_channel_id
        WHERE ra.egress_channel_id = ?
        """,
        (egress_id,),
    )
    return row_to_dict(cur.fetchone())


def _kill() -> None:
    global _proc
    if _proc is None:
        return
    if _proc.poll() is None:
        _proc.terminate()
        try:
            _proc.wait(timeout=5)
        except Exception:
            _proc.kill()
    _proc = None


def main() -> int:
    global _proc, _stop

    parser = argparse.ArgumentParser(description="NexBreak egress channel")
    parser.add_argument("--service-name", required=True)
    parser.add_argument("--db", default=None)
    parser.add_argument("--once", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle_signal)
    signal.signal(signal.SIGTERM, _handle_signal)

    conn = connect(args.db)
    try:
        channel = get_egress_by_service(conn, args.service_name)
        if channel is None:
            log.error("no egress_channels row for service_name=%r", args.service_name)
            return 1
        if not channel["enabled"]:
            log.warning("egress %s disabled — exiting", channel["name"])
            return 0

        source = _routed_source(conn, channel["id"])
        if source is None:
            log.error("egress %s has no routing assignment — configure router first", channel["name"])
            return 1

        feed_host = source["local_feed_host"] or "127.0.0.1"
        feed_port = int(source["local_feed_port"])
        feed_dest = resolve_local_feed_host(feed_host)
        log.info(
            "plan: %s type=%s ← %s (%s:%s → %s:%s) srt_mode=%s",
            channel["name"],
            channel["output_type"],
            source["name"],
            feed_host,
            feed_port,
            feed_dest,
            feed_port,
            channel.get("srt_mode"),
        )

        if args.once or args.dry_run:
            bins = require_bins("ffmpeg")
            argv = ffmpeg_egress_argv(
                ffmpeg=bins["ffmpeg"],
                feed_host=feed_host,
                feed_port=feed_port,
                egress=channel,
            )
            print("FFMPEG", " ".join(argv))
            return 0

        try:
            bins = require_bins("ffmpeg")
            argv = ffmpeg_egress_argv(
                ffmpeg=bins["ffmpeg"],
                feed_host=feed_host,
                feed_port=feed_port,
                egress=channel,
            )
        except Exception as exc:  # noqa: BLE001
            log.error("egress config error: %s", exc)
            return 1

        log.info("ffmpeg: %s", " ".join(argv))
        _proc = Popen(argv)

        audit(
            conn,
            event_type="service_start",
            egress_channel_id=channel["id"],
            processing_channel_id=source["id"],
            detail=(
                f"nexbreak-egress@{args.service_name} up; "
                f"udp://{feed_host}:{feed_port} → {channel['output_type']}"
            ),
        )

        rc = 0
        restart_at = 0.0
        while not _stop:
            if _proc is not None and _proc.poll() is not None:
                code = _proc.returncode
                now = time.time()
                if now < restart_at:
                    time.sleep(0.2)
                    continue
                log.warning("ffmpeg exited code=%s — restarting in 2s", code)
                audit(
                    conn,
                    event_type="service_crash",
                    egress_channel_id=channel["id"],
                    result="failure",
                    detail=f"ffmpeg exited {code}; auto-restart",
                )
                restart_at = now + 2.0
                time.sleep(2.0)
                if _stop:
                    break
                _proc = Popen(argv)
                continue
            time.sleep(0.5)

        _kill()
        audit(
            conn,
            event_type="service_stop",
            egress_channel_id=channel["id"],
            detail=f"nexbreak-egress@{args.service_name} stopped",
        )
        return rc
    finally:
        conn.close()


if __name__ == "__main__":
    raise SystemExit(main())
