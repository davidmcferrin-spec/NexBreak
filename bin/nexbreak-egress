#!/usr/bin/env python3
"""
nexbreak-egress — local feed → SRT (v1) / HLS (later).

Reads the MPEG-TS UDP feed currently assigned by routing_assignments
(processing local_feed_host:port) and pushes SRT via ffmpeg+libsrt.

Self-healing: ffmpeg is restarted on exit. SRT listener URLs use
peeridletimeout so a dropped client tears down the session; stderr is
watched for mux I/O errors so a hung-but-alive ffmpeg is killed and
recycled for the next VLC/connect.
"""

from __future__ import annotations

import argparse
import logging
import signal
import sys
import threading
import time
from pathlib import Path
from subprocess import PIPE, STDOUT, Popen
from typing import Any, Optional

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_db import audit, connect, get_egress_by_service, row_to_dict  # noqa: E402
from nexbreak_pipeline import (  # noqa: E402
    ffmpeg_egress_argv,
    require_bins,
    resolve_local_feed_host,
)

log = logging.getLogger("nexbreak-egress")
_stop = False
_proc: Optional[Popen] = None
_kill_requested = False

# stderr lines that mean the SRT session is dead but ffmpeg may still be alive
_FATAL_MARKERS = (
    "error submitting a packet to the muxer",
    "error muxing a packet",
    "error writing trailer",
    "error closing file",
    "input/output error",
    "connection timed out",
    "broken pipe",
)


def _handle_signal(signum, _frame):
    global _stop
    log.info("signal %s — shutting down", signum)
    _stop = True
    # Kill ffmpeg immediately — SRT listener otherwise blocks until the client leaves.
    _kill(grace_s=0.4)


def _routed_source(conn, egress_id: int) -> Optional[dict[str, Any]]:
    cur = conn.execute(
        """
        SELECT pc.*
        FROM routing_assignments ra
        JOIN processing_channels pc ON pc.id = ra.processing_channel_id
        WHERE ra.egress_channel_id = ?
        """,
        (egress_id,),
    )
    return row_to_dict(cur.fetchone())


def _kill(grace_s: float = 1.0) -> None:
    global _proc
    if _proc is None:
        return
    proc = _proc
    _proc = None
    if proc.poll() is None:
        try:
            proc.terminate()
        except Exception:
            pass
        try:
            proc.wait(timeout=max(0.2, grace_s))
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass
            try:
                proc.wait(timeout=1.0)
            except Exception:
                pass


def _stderr_watch(proc: Popen, stream) -> None:
    """Kill ffmpeg if SRT mux is clearly dead (avoids hung listener)."""
    global _kill_requested
    try:
        for raw in stream:
            if _stop:
                break
            line = raw.decode("utf-8", errors="replace").strip()
            if not line:
                continue
            low = line.lower()
            if any(m in low for m in _FATAL_MARKERS):
                log.warning("ffmpeg SRT fault — recycling: %s", line[:200])
                _kill_requested = True
                try:
                    proc.terminate()
                except Exception:
                    pass
                time.sleep(1.0)
                if proc.poll() is None:
                    try:
                        proc.kill()
                    except Exception:
                        pass
                break
            # Surface non-fatal ffmpeg lines so journal still shows activity.
            if "non-existing pps" not in low and "no frame" not in low:
                log.info("ffmpeg: %s", line[:300])
    except Exception as exc:  # noqa: BLE001
        log.debug("stderr watch ended: %s", exc)


def _spawn(argv: list[str]) -> Popen:
    global _kill_requested
    _kill_requested = False
    proc = Popen(argv, stdout=PIPE, stderr=STDOUT)
    t = threading.Thread(
        target=_stderr_watch,
        args=(proc, proc.stdout),
        daemon=True,
        name="egress-ff-watch",
    )
    t.start()
    return proc


def main() -> int:
    global _proc, _stop, _kill_requested

    parser = argparse.ArgumentParser(description="NexBreak egress channel")
    parser.add_argument("--service-name", required=True)
    parser.add_argument("--db", default=None)
    parser.add_argument("--once", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle_signal)
    signal.signal(signal.SIGTERM, _handle_signal)

    conn = connect(args.db)
    try:
        channel = get_egress_by_service(conn, args.service_name)
        if channel is None:
            log.error("no egress_channels row for service_name=%r", args.service_name)
            return 1
        if not channel["enabled"]:
            log.warning("egress %s disabled — exiting", channel["name"])
            return 0

        source = _routed_source(conn, channel["id"])
        if source is None:
            log.error("egress %s has no routing assignment — configure router first", channel["name"])
            return 1

        feed_host = source["local_feed_host"] or "127.0.0.1"
        feed_port = int(source["local_feed_port"])
        feed_dest = resolve_local_feed_host(feed_host)
        log.info(
            "plan: %s type=%s ← %s (%s:%s → %s:%s) srt_mode=%s",
            channel["name"],
            channel["output_type"],
            source["name"],
            feed_host,
            feed_port,
            feed_dest,
            feed_port,
            channel.get("srt_mode"),
        )

        if args.once or args.dry_run:
            bins = require_bins("ffmpeg")
            argv = ffmpeg_egress_argv(
                ffmpeg=bins["ffmpeg"],
                feed_host=feed_host,
                feed_port=feed_port,
                egress=channel,
            )
            print("FFMPEG", " ".join(argv))
            return 0

        try:
            bins = require_bins("ffmpeg")
            argv = ffmpeg_egress_argv(
                ffmpeg=bins["ffmpeg"],
                feed_host=feed_host,
                feed_port=feed_port,
                egress=channel,
            )
        except Exception as exc:  # noqa: BLE001
            log.error("egress config error: %s", exc)
            return 1

        log.info("ffmpeg: %s", " ".join(argv))
        if "peeridletimeout=" not in " ".join(argv):
            log.error(
                "BUG: SRT URL missing peeridletimeout — wrong nexbreak_pipeline deployed?"
            )
        _proc = _spawn(argv)

        audit(
            conn,
            event_type="service_start",
            egress_channel_id=channel["id"],
            processing_channel_id=source["id"],
            detail=(
                f"nexbreak-egress@{args.service_name} up; "
                f"udp://{feed_host}:{feed_port} → {channel['output_type']} "
                f"(self-heal on SRT peer drop)"
            ),
        )

        rc = 0
        restart_at = 0.0
        backoff = 0.5
        while not _stop:
            if _proc is not None and _proc.poll() is not None:
                code = _proc.returncode
                reason = "srt-fault" if _kill_requested else f"exit-{code}"
                now = time.time()
                if now < restart_at:
                    time.sleep(0.1)
                    continue
                log.warning(
                    "ffmpeg recycled (%s code=%s) — restarting in %.1fs",
                    reason,
                    code,
                    backoff,
                )
                try:
                    audit(
                        conn,
                        event_type="service_crash",
                        egress_channel_id=channel["id"],
                        result="failure",
                        detail=f"ffmpeg {reason} code={code}; auto-restart",
                    )
                except Exception:
                    pass
                restart_at = now + backoff
                time.sleep(backoff)
                # Brief pause so SRT listen port is released.
                time.sleep(0.2)
                backoff = min(15.0, max(0.5, backoff * 1.4))
                if _stop:
                    break
                _proc = _spawn(argv)
                continue
            # Healthy run — decay backoff toward fast reconnect.
            if _proc is not None and _proc.poll() is None and backoff > 0.5:
                backoff = max(0.5, backoff * 0.9)
            time.sleep(0.25)

        _kill()
        audit(
            conn,
            event_type="service_stop",
            egress_channel_id=channel["id"],
            detail=f"nexbreak-egress@{args.service_name} stopped",
        )
        return rc
    finally:
        conn.close()


if __name__ == "__main__":
    raise SystemExit(main())
