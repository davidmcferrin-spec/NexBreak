#!/usr/bin/env python3
"""
nexbreak-caption-worker — per-stream ASR → cue socket for cc-inject.

- Taps audio from the local MPEG-TS UDP feed (ffmpeg → s16le 16 kHz mono).
- Optional Vosk when model + package available.
- Applies caption_blacklist / caption_lexicon from SQLite.
- Publishes JSON cues paced for live CEA-608 readability (FCC/WCAG-oriented):
    • debounce / max lag so text appears within ~2–3s of speech
    • min on-screen dwell ≥1.5s between rolls
    • clear after max dwell 6s with no new text
    • prefer ~32-char CEA-608 row chunks at a readable pace
  Never blocks the media path.

Stdlib preferred; vosk is optional.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import re
import shutil
import signal
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import Optional

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_caption_policy import cue_sock_path  # noqa: E402
from nexbreak_db import connect, migrate  # noqa: E402
from nexbreak_pipeline import udp_mpegts_input_url  # noqa: E402
from nexbreak_verify import asr_state_path, atomic_write_json  # noqa: E402

log = logging.getLogger("nexbreak-caption-worker")
_stop = False

# Live CC pacing (FCC TV / WCAG-oriented defaults for CEA-608).
# Override via env without code changes.
_DEFAULT_DEBOUNCE_MS = 500  # pause before committing a stable hypothesis
_DEFAULT_MIN_DWELL_MS = 1500  # min time a caption stays before the next roll
_DEFAULT_MAX_DWELL_MS = 6000  # clear if nothing new
_DEFAULT_MAX_LAG_MS = 2500  # force commit so lag stays in the 2–3s window
_DEFAULT_ROW_CHARS = 32  # CEA-608 row width — natural chunk boundary


def _env_ms(name: str, default_ms: int, *, lo: int = 100, hi: int = 15000) -> float:
    raw = os.environ.get(name, str(default_ms))
    try:
        ms = int(float(raw))
    except (TypeError, ValueError):
        ms = default_ms
    return max(lo, min(hi, ms)) / 1000.0


def _env_int(name: str, default: int, *, lo: int = 8, hi: int = 64) -> int:
    raw = os.environ.get(name, str(default))
    try:
        v = int(float(raw))
    except (TypeError, ValueError):
        v = default
    return max(lo, min(hi, v))


def cea608_chunk(text: str, width: int = 32) -> str:
    """
    Fit a live caption into one CEA-608 row (~32 chars).
    Prefer the most recent words so the on-screen line tracks speech.
    """
    text = (text or "").strip()
    if not text or len(text) <= width:
        return text
    window = text[-width:]
    # If the clip started mid-word, drop the partial leading token.
    if len(text) > width and text[-width - 1] not in " \t" and " " in window:
        window = window.split(" ", 1)[-1]
    return window.strip() or text[:width]


class CaptionPacer:
    """
    Gate cue emits for readability + sync:
      - min dwell between on-screen updates
      - coalesce newer text while dwelling
      - clear after max dwell
    """

    def __init__(
        self,
        *,
        min_dwell_s: float,
        max_dwell_s: float,
        debounce_s: float,
        max_lag_s: float,
        row_chars: int,
    ) -> None:
        self.min_dwell_s = min_dwell_s
        self.max_dwell_s = max_dwell_s
        self.debounce_s = debounce_s
        self.max_lag_s = max_lag_s
        self.row_chars = row_chars
        self.last_sent = ""
        self.last_sent_at = 0.0
        self.pending: Optional[str] = None
        self.segment_started_at = 0.0

    def note_partial_growth(self, now: float, had_text: bool) -> None:
        if had_text and self.segment_started_at <= 0:
            self.segment_started_at = now
        if not had_text:
            self.segment_started_at = 0.0

    def request(self, text: str, now: float) -> Optional[str]:
        """Queue or immediately release a caption line. Returns text to send, or None."""
        text = (text or "").strip()
        if not text or text == self.last_sent:
            return None
        if self.last_sent and (now - self.last_sent_at) < self.min_dwell_s:
            self.pending = text
            return None
        return self._release(text, now)

    def flush_due(self, now: float) -> Optional[str]:
        if not self.pending:
            return None
        if self.last_sent and (now - self.last_sent_at) < self.min_dwell_s:
            return None
        text = self.pending
        self.pending = None
        if not text or text == self.last_sent:
            return None
        return self._release(text, now)

    def clear_due(self, now: float, *, speech_active: bool) -> bool:
        if speech_active or not self.last_sent:
            return False
        return (now - self.last_sent_at) >= self.max_dwell_s

    def should_force_row(self, partial: str) -> bool:
        if not partial or len(partial) < self.row_chars:
            return False
        chunk = cea608_chunk(partial, self.row_chars)
        return bool(chunk) and chunk != self.last_sent

    def should_force_lag(self, now: float, partial: str) -> bool:
        if not partial:
            return False
        chunk = cea608_chunk(partial, self.row_chars)
        if not chunk or chunk == self.last_sent:
            return False
        if self.segment_started_at <= 0:
            return False
        return (now - self.segment_started_at) >= self.max_lag_s

    def mark_cleared(self, now: float) -> None:
        self.last_sent = ""
        self.last_sent_at = now
        self.pending = None
        self.segment_started_at = 0.0

    def _release(self, text: str, now: float) -> str:
        self.last_sent = text
        self.last_sent_at = now
        self.pending = None
        # Continued speech after a forced row/lag commit starts a new lag window.
        self.segment_started_at = now if text else 0.0
        return text


def write_asr_state(service_name: str, **fields) -> None:
    path = asr_state_path(str(service_name))
    payload = {
        "service_name": str(service_name),
        "ts": time.time(),
    }
    payload.update(fields)
    try:
        atomic_write_json(path, payload)
    except Exception as exc:  # noqa: BLE001
        log.debug("asr state write failed: %s", exc)


def _handle(signum, _frame):
    global _stop
    log.info("signal %s — clean exit (captions only)", signum)
    _stop = True


def try_load_vosk(model_path: str):
    if not model_path:
        return None, "no model path — idle bypass-ready"
    if not os.path.isdir(model_path):
        return None, f"model path missing: {model_path}"
    try:
        from vosk import Model  # type: ignore
    except ImportError:
        return None, "vosk package not installed — idle bypass-ready"
    try:
        return Model(model_path), f"vosk model loaded from {model_path}"
    except Exception as exc:  # noqa: BLE001
        return None, f"vosk load failed: {exc}"


def load_lists(db_path: Optional[str]) -> tuple[set[str], dict[str, str]]:
    blacklist: set[str] = set()
    lexicon: dict[str, str] = {}
    try:
        conn = connect(db_path)
        migrate(conn)
        for row in conn.execute("SELECT word FROM caption_blacklist").fetchall():
            w = (row[0] or "").strip().lower()
            if w:
                blacklist.add(w)
        for row in conn.execute("SELECT word, phonetic FROM caption_lexicon").fetchall():
            w = (row[0] or "").strip()
            ph = (row[1] or "").strip()
            if w and ph:
                lexicon[w.lower()] = ph
        conn.close()
    except Exception as exc:  # noqa: BLE001
        log.warning("caption lists unavailable: %s", exc)
    return blacklist, lexicon


def apply_text(text: str, blacklist: set[str], lexicon: dict[str, str]) -> str:
    if not text:
        return ""
    # Lexicon is primarily for ASR pronunciation; light post-replace for display variants.
    words = text.split()
    out: list[str] = []
    for w in words:
        bare = re.sub(r"[^\w']+", "", w).lower()
        if bare and bare in blacklist:
            continue  # omit entirely — no placeholder
        out.append(w)
    return " ".join(out).strip()


def connect_cues(sock_path: str, retries: int = 40) -> Optional[socket.socket]:
    for i in range(retries):
        if _stop:
            return None
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        try:
            s.connect(sock_path)
            s.settimeout(2.0)
            log.info("connected to cue socket %s", sock_path)
            return s
        except OSError:
            s.close()
            time.sleep(0.25)
    log.warning("cue socket %s not ready — will retry in loop", sock_path)
    return None


def send_cue(sock: Optional[socket.socket], *, text: str, clear: bool, seq: int) -> Optional[socket.socket]:
    payload = (json.dumps({"text": text, "clear": clear, "seq": seq}) + "\n").encode("utf-8")
    if sock is None:
        return None
    try:
        sock.sendall(payload)
        return sock
    except OSError:
        try:
            sock.close()
        except OSError:
            pass
        return None


def parse_cc_udp(spec: str) -> Optional[tuple[str, int]]:
    spec = (spec or "").strip()
    if not spec or ":" not in spec:
        return None
    host, _, port_s = spec.rpartition(":")
    try:
        return (host.strip() or "127.0.0.1", int(port_s))
    except ValueError:
        return None


def send_cc_udp(
    udp: Optional[socket.socket],
    addr: Optional[tuple[str, int]],
    text: str,
) -> None:
    """Optional direct LCE UDP (unused by default — cue→bridge owns inject)."""
    if udp is None or addr is None:
        return
    line = (text or "").replace("\r", " ").replace("\n", " ").strip()
    if not line:
        return
    if len(line) > 32:
        line = line[:31].rstrip() + "…"
    try:
        udp.sendto(line.encode("ascii", errors="replace") + b"\n", addr)
    except OSError:
        pass


def audio_tap_argv(ffmpeg: str, host: str, port: int) -> list[str]:
    src = udp_mpegts_input_url(host, int(port), fifo_size=500000)
    return [
        ffmpeg,
        "-hide_banner",
        "-loglevel",
        "error",
        "-nostdin",
        "-i",
        src,
        "-vn",
        "-ac",
        "1",
        "-ar",
        "16000",
        "-f",
        "s16le",
        "pipe:1",
    ]


def main() -> int:
    parser = argparse.ArgumentParser(description="NexBreak caption/Vosk worker")
    parser.add_argument("--service-name", required=True)
    parser.add_argument("--feed-host", default="127.0.0.1")
    parser.add_argument("--feed-port", type=int, required=True)
    parser.add_argument("--db", default=None)
    parser.add_argument("--model", default=os.environ.get("NEXBREAK_VOSK_MODEL", ""))
    parser.add_argument("--cue-sock", default=None)
    parser.add_argument(
        "--cc-udp",
        default=os.environ.get("NEXBREAK_CC_UDP", ""),
        help="optional HOST:PORT for Live Caption Encoder text UDP",
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle)
    signal.signal(signal.SIGTERM, _handle)

    sock_path = args.cue_sock or cue_sock_path(args.service_name)
    blacklist, lexicon = load_lists(args.db)
    model, reason = try_load_vosk(args.model or "")
    if args.cc_udp:
        log.warning(
            "--cc-udp ignored (captions go cue→cc-inject bridge only; "
            "direct UDP caused duplicate inject)"
        )
    log.info(
        "caption worker up service=%s feed=%s:%s cues=%s — %s (blacklist=%s lexicon=%s)",
        args.service_name,
        args.feed_host,
        args.feed_port,
        sock_path,
        reason,
        len(blacklist),
        len(lexicon),
    )

    cue = connect_cues(sock_path)
    seq = 0
    model_path = (args.model or "").strip()

    write_asr_state(
        args.service_name,
        vosk_loaded=model is not None,
        model=model_path,
        reason=reason,
        cue_connected=cue is not None,
        state="idle_bypass" if model is None else "starting",
        partial="",
        final="",
        seq=0,
        audio_tap_alive=False,
    )

    if model is None:
        # Stay alive; send periodic clears so inject does not stall on stale text.
        while not _stop:
            if cue is None:
                cue = connect_cues(sock_path, retries=8)
            seq += 1
            cue = send_cue(cue, text="", clear=True, seq=seq)
            write_asr_state(
                args.service_name,
                vosk_loaded=False,
                model=model_path,
                reason=reason,
                cue_connected=cue is not None,
                state="idle_bypass",
                partial="",
                final="",
                seq=seq,
                audio_tap_alive=False,
            )
            time.sleep(2.0)
        if cue:
            try:
                cue.close()
            except OSError:
                pass
        write_asr_state(
            args.service_name,
            vosk_loaded=False,
            model=model_path,
            reason=reason,
            cue_connected=False,
            state="stopped",
            partial="",
            final="",
            seq=seq,
            audio_tap_alive=False,
        )
        return 0

    from vosk import KaldiRecognizer  # type: ignore

    rec = KaldiRecognizer(model, 16000)
    rec.SetWords(True)
    # Push lexicon terms into grammar lightly via accept waveform only;
    # full Kaldi lexicon rewrite needs model rebuild — phonetic list is logged for ops.
    if lexicon:
        log.info("lexicon loaded (%s entries) — used as recognition hints when possible", len(lexicon))

    ffmpeg = shutil.which("ffmpeg") or os.environ.get("NEXBREAK_FFMPEG", "ffmpeg")
    tap = subprocess.Popen(
        audio_tap_argv(ffmpeg, args.feed_host, args.feed_port),
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    assert tap.stdout is not None
    last_partial = ""
    last_final = ""
    partial_changed_at = 0.0
    last_state_write = 0.0
    pacer = CaptionPacer(
        min_dwell_s=_env_ms("NEXBREAK_CAPTION_MIN_DWELL_MS", _DEFAULT_MIN_DWELL_MS),
        max_dwell_s=_env_ms(
            "NEXBREAK_CAPTION_MAX_DWELL_MS", _DEFAULT_MAX_DWELL_MS, lo=2000, hi=20000
        ),
        debounce_s=_env_ms("NEXBREAK_CAPTION_DEBOUNCE_MS", _DEFAULT_DEBOUNCE_MS),
        max_lag_s=_env_ms(
            "NEXBREAK_CAPTION_MAX_LAG_MS", _DEFAULT_MAX_LAG_MS, lo=500, hi=5000
        ),
        row_chars=_env_int("NEXBREAK_CAPTION_ROW_CHARS", _DEFAULT_ROW_CHARS),
    )
    log.info(
        "caption pacing debounce=%.2fs min_dwell=%.2fs max_dwell=%.2fs max_lag=%.2fs row=%s",
        pacer.debounce_s,
        pacer.min_dwell_s,
        pacer.max_dwell_s,
        pacer.max_lag_s,
        pacer.row_chars,
    )

    def emit(text: str, reason: str) -> None:
        nonlocal cue, seq, last_final
        line = cea608_chunk(text, pacer.row_chars) if text else ""
        out = pacer.request(line, time.time()) if line else None
        if not out:
            return
        seq += 1
        cue = send_cue(cue, text=out, clear=False, seq=seq)
        last_final = out
        log.info("caption cue (%s): %s", reason, out[:120])

    def emit_clear(reason: str) -> None:
        nonlocal cue, seq
        seq += 1
        cue = send_cue(cue, text="", clear=True, seq=seq)
        pacer.mark_cleared(time.time())
        log.info("caption cue (clear:%s)", reason)

    write_asr_state(
        args.service_name,
        vosk_loaded=True,
        model=model_path,
        reason=reason,
        cue_connected=cue is not None,
        state="listening",
        partial="",
        final="",
        seq=0,
        audio_tap_alive=True,
    )
    try:
        while not _stop:
            if tap.poll() is not None:
                log.warning("audio tap exited %s — restarting in 2s", tap.returncode)
                write_asr_state(
                    args.service_name,
                    vosk_loaded=True,
                    model=model_path,
                    reason=reason,
                    cue_connected=cue is not None,
                    state="tap_restart",
                    partial=last_partial,
                    final=last_final,
                    seq=seq,
                    audio_tap_alive=False,
                )
                time.sleep(2.0)
                if _stop:
                    break
                tap = subprocess.Popen(
                    audio_tap_argv(ffmpeg, args.feed_host, args.feed_port),
                    stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                )
                assert tap.stdout is not None
                continue

            data = tap.stdout.read(4000)
            if not data:
                time.sleep(0.02)
                continue

            if cue is None:
                cue = connect_cues(sock_path, retries=4)

            now = time.time()
            state_name = "listening"
            if rec.AcceptWaveform(data):
                try:
                    result = json.loads(rec.Result())
                except json.JSONDecodeError:
                    result = {}
                text = apply_text(str(result.get("text") or ""), blacklist, lexicon)
                last_partial = ""
                partial_changed_at = 0.0
                pacer.note_partial_growth(now, False)
                if text:
                    last_final = text
                    state_name = "final"
                    emit(text, "final")
            else:
                try:
                    partial = json.loads(rec.PartialResult())
                except json.JSONDecodeError:
                    partial = {}
                ptext = apply_text(str(partial.get("partial") or ""), blacklist, lexicon)
                if ptext != last_partial:
                    last_partial = ptext
                    if ptext:
                        partial_changed_at = now
                        state_name = "partial"
                    pacer.note_partial_growth(now, bool(ptext))
                elif last_partial:
                    state_name = "partial"

                if last_partial and last_partial != pacer.last_sent:
                    if pacer.should_force_row(last_partial):
                        emit(last_partial, "row")
                        state_name = "row"
                    elif pacer.should_force_lag(now, last_partial):
                        emit(last_partial, "lag")
                        state_name = "lag"
                    elif (
                        partial_changed_at > 0
                        and (now - partial_changed_at) >= pacer.debounce_s
                    ):
                        emit(last_partial, "stable")
                        state_name = "stable"

            due = pacer.flush_due(now)
            if due:
                seq += 1
                cue = send_cue(cue, text=due, clear=False, seq=seq)
                last_final = due
                state_name = "dwell"
                log.info("caption cue (dwell): %s", due[:120])

            if pacer.clear_due(now, speech_active=bool(last_partial)):
                emit_clear("max_dwell")
                state_name = "clear"

            if state_name in ("partial", "final", "stable", "row", "lag", "dwell", "clear") or (
                now - last_state_write
            ) >= 1.0:
                last_state_write = now
                write_asr_state(
                    args.service_name,
                    vosk_loaded=True,
                    model=model_path,
                    reason=reason,
                    cue_connected=cue is not None,
                    state=(
                        state_name
                        if last_partial or state_name in ("final", "stable", "row", "lag", "dwell")
                        else "listening"
                    ),
                    partial=last_partial,
                    final=last_final,
                    seq=seq,
                    audio_tap_alive=tap.poll() is None,
                )
    finally:
        if tap.poll() is None:
            tap.terminate()
            try:
                tap.wait(timeout=3)
            except Exception:
                tap.kill()
        if cue:
            seq += 1
            send_cue(cue, text="", clear=True, seq=seq)
            try:
                cue.close()
            except OSError:
                pass
        del model
        write_asr_state(
            args.service_name,
            vosk_loaded=False,
            model=model_path,
            reason="unloaded",
            cue_connected=False,
            state="stopped",
            partial="",
            final=last_final,
            seq=seq,
            audio_tap_alive=False,
        )
        # (direct --cc-udp path removed — cue→cc-inject bridge owns inject;
        #  no UDP socket to close here)
        log.info("caption worker exit (vosk unloaded)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
