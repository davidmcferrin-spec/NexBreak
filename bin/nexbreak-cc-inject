#!/usr/bin/env python3
"""
nexbreak-cc-inject — MPEG-TS in → H.264(+A53 CEA-608) MPEG-TS out.

Sits between ffmpeg ingest and tsp when effective_mode=asr_insert.

Architecture (deliberately simple — no named FIFOs, no dual ffmpeg outputs):
  stdin MPEG-TS
    → ffmpeg (decode/re-encode H.264+AAC → Annex-B on fd + AAC on fd via pass_fds)
    → this process injects A/53 SEI into the H.264 Annex-B
    → ffmpeg mux (H.264+AAC → MPEG-TS stdout)

If the dual-pipe encode fails to start, falls back to a single ffmpeg
H.264+AAC MPEG-TS remux (no SEI) so the program path stays alive.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import select
import shutil
import signal
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Optional

sys.path.insert(0, str(Path(__file__).resolve().parent))

from nexbreak_cea608 import annex_b_sei_nal, cc_pair, text_to_cc_pairs  # noqa: E402

log = logging.getLogger("nexbreak-cc-inject")
_stop = False
_caption_text = ""
_caption_clear = True
_caption_seq = 0
_caption_lock = threading.Lock()


def _handle(signum, _frame):
    global _stop
    _stop = True


def _set_caption(text: str, clear: bool, seq: int) -> None:
    global _caption_text, _caption_clear, _caption_seq
    with _caption_lock:
        if seq and seq < _caption_seq:
            return
        _caption_seq = seq or (_caption_seq + 1)
        _caption_text = text or ""
        _caption_clear = bool(clear) or not _caption_text


def _get_caption() -> tuple[str, bool, int]:
    with _caption_lock:
        return _caption_text, _caption_clear, _caption_seq


def cue_listener(sock_path: str) -> None:
    Path(sock_path).parent.mkdir(parents=True, exist_ok=True)
    if os.path.exists(sock_path):
        try:
            os.unlink(sock_path)
        except OSError:
            pass
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(sock_path)
    srv.listen(4)
    os.chmod(sock_path, 0o660)
    srv.settimeout(1.0)
    log.info("cue socket %s", sock_path)
    clients: list[socket.socket] = []
    bufmap: dict[socket.socket, bytes] = {}
    try:
        while not _stop:
            try:
                conn, _ = srv.accept()
                conn.setblocking(False)
                clients.append(conn)
                bufmap[conn] = b""
            except socket.timeout:
                pass
            except OSError:
                if _stop:
                    break
            if not clients:
                continue
            readable, _, _ = select.select(clients, [], [], 0.25)
            for c in readable:
                try:
                    data = c.recv(4096)
                except OSError:
                    data = b""
                if not data:
                    try:
                        c.close()
                    except OSError:
                        pass
                    clients = [x for x in clients if x is not c]
                    bufmap.pop(c, None)
                    continue
                bufmap[c] = bufmap.get(c, b"") + data
                while b"\n" in bufmap[c]:
                    line, bufmap[c] = bufmap[c].split(b"\n", 1)
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        msg = json.loads(line.decode("utf-8", errors="replace"))
                    except json.JSONDecodeError:
                        continue
                    _set_caption(
                        str(msg.get("text") or ""),
                        bool(msg.get("clear")),
                        int(msg.get("seq") or 0),
                    )
    finally:
        for c in list(clients):
            try:
                c.close()
            except OSError:
                pass
        try:
            srv.close()
        except OSError:
            pass
        try:
            os.unlink(sock_path)
        except OSError:
            pass


def _nal_type(buf: bytes, sc: int) -> Optional[int]:
    if sc + 4 <= len(buf) and buf[sc : sc + 3] == b"\x00\x00\x01":
        hdr = sc + 3
    elif sc + 5 <= len(buf) and buf[sc : sc + 4] == b"\x00\x00\x00\x01":
        hdr = sc + 4
    else:
        return None
    if hdr >= len(buf):
        return None
    return buf[hdr] & 0x1F


def _iter_start_codes(buf: bytes) -> list[int]:
    out: list[int] = []
    i = 0
    n = len(buf)
    while i + 3 < n:
        if buf[i] == 0 and buf[i + 1] == 0:
            if buf[i + 2] == 1:
                out.append(i)
                i += 3
                continue
            if buf[i + 2] == 0 and i + 3 < n and buf[i + 3] == 1:
                out.append(i)
                i += 4
                continue
        i += 1
    return out


def sei_filter_fds(src_fd: int, dst_fd: int) -> None:
    last_seq = -1
    pairs: list = [cc_pair(0x00, 0x00)]
    pair_i = 0
    carry = b""
    frames = 0
    try:
        while not _stop:
            try:
                chunk = os.read(src_fd, 65536)
            except OSError:
                break
            if not chunk:
                break
            buf = carry + chunk
            scs = _iter_start_codes(buf)
            if not scs:
                carry = buf[-3:] if len(buf) >= 3 else buf
                if len(buf) > 3:
                    try:
                        os.write(dst_fd, buf[:-3])
                    except OSError:
                        break
                continue

            text, clear, seq = _get_caption()
            if seq != last_seq:
                last_seq = seq
                pairs = text_to_cc_pairs(text, clear=clear) or [cc_pair(0x00, 0x00)]
                pair_i = 0

            out = bytearray()
            for i, sc in enumerate(scs[:-1]):
                end = scs[i + 1]
                nal = buf[sc:end]
                nt = _nal_type(buf, sc)
                if nt is not None and nt in (1, 5):
                    frames += 1
                    if frames % 2 == 0:
                        sei = annex_b_sei_nal([pairs[pair_i % len(pairs)]])
                        pair_i += 1
                        out.extend(sei)
                out.extend(nal)
            if out:
                try:
                    os.write(dst_fd, out)
                except OSError:
                    break
            carry = buf[scs[-1] :]
        if carry:
            try:
                os.write(dst_fd, carry)
            except OSError:
                pass
    finally:
        for fd in (src_fd, dst_fd):
            try:
                os.close(fd)
            except OSError:
                pass


def run_simple(ffmpeg: str, bitrate: str) -> int:
    """Single-process H.264+AAC remux — always keeps the TS flowing (no SEI)."""
    log.warning("cc-inject simple mode (H.264 remux, no A53 SEI)")
    proc = subprocess.Popen(
        [
            ffmpeg,
            "-hide_banner",
            "-loglevel",
            "error",
            "-fflags",
            "+genpts+discardcorrupt",
            "-i",
            "pipe:0",
            "-map",
            "0:v:0",
            "-map",
            "0:a:0?",
            "-c:v",
            "libx264",
            "-preset",
            "ultrafast",
            "-tune",
            "zerolatency",
            "-profile:v",
            "main",
            "-pix_fmt",
            "yuv420p",
            "-b:v",
            bitrate,
            "-maxrate",
            bitrate,
            "-bufsize",
            "8M",
            "-g",
            "30",
            "-c:a",
            "aac",
            "-b:a",
            "128k",
            "-ac",
            "2",
            "-ar",
            "48000",
            "-f",
            "mpegts",
            "-mpegts_flags",
            "+resend_headers",
            "pipe:1",
        ],
        stdin=sys.stdin.buffer,
        stdout=sys.stdout.buffer,
        stderr=None,
    )
    try:
        while not _stop:
            code = proc.poll()
            if code is not None:
                return int(code or 0)
            time.sleep(0.2)
    finally:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=3)
            except Exception:
                proc.kill()
    return 0


def run_with_sei(ffmpeg: str, bitrate: str) -> int:
    """Encode → SEI filter → mux using anonymous pipes only."""
    raw_v_r, raw_v_w = os.pipe()
    raw_a_r, raw_a_w = os.pipe()
    inj_r, inj_w = os.pipe()

    enc = subprocess.Popen(
        [
            ffmpeg,
            "-hide_banner",
            "-loglevel",
            "error",
            "-fflags",
            "+genpts+discardcorrupt",
            "-i",
            "pipe:0",
            "-map",
            "0:v:0",
            "-c:v",
            "libx264",
            "-preset",
            "ultrafast",
            "-tune",
            "zerolatency",
            "-profile:v",
            "main",
            "-pix_fmt",
            "yuv420p",
            "-b:v",
            bitrate,
            "-maxrate",
            bitrate,
            "-bufsize",
            "8M",
            "-g",
            "30",
            "-an",
            "-f",
            "h264",
            f"pipe:{raw_v_w}",
            "-map",
            "0:a:0?",
            "-c:a",
            "aac",
            "-b:a",
            "128k",
            "-ac",
            "2",
            "-ar",
            "48000",
            "-vn",
            "-f",
            "adts",
            f"pipe:{raw_a_w}",
        ],
        stdin=sys.stdin.buffer,
        stdout=subprocess.DEVNULL,
        stderr=None,
        pass_fds=(raw_v_w, raw_a_w),
    )
    os.close(raw_v_w)
    os.close(raw_a_w)

    threading.Thread(
        target=sei_filter_fds, args=(raw_v_r, inj_w), daemon=True, name="sei-filter"
    ).start()

    mux = subprocess.Popen(
        [
            ffmpeg,
            "-hide_banner",
            "-loglevel",
            "error",
            "-fflags",
            "+genpts",
            "-thread_queue_size",
            "512",
            "-f",
            "h264",
            "-i",
            f"pipe:{inj_r}",
            "-thread_queue_size",
            "512",
            "-f",
            "aac",
            "-i",
            f"pipe:{raw_a_r}",
            "-map",
            "0:v:0",
            "-map",
            "1:a:0?",
            "-c",
            "copy",
            "-f",
            "mpegts",
            "-mpegts_flags",
            "+resend_headers",
            "pipe:1",
        ],
        stdout=sys.stdout.buffer,
        stderr=None,
        pass_fds=(inj_r, raw_a_r),
    )
    os.close(inj_r)
    os.close(raw_a_r)

    log.info("cc-inject up (pipe+SEI H.264+A53)")
    rc = 0
    try:
        while not _stop:
            if enc.poll() is not None:
                log.error("encode stage exited %s", enc.returncode)
                rc = enc.returncode if enc.returncode else 1
                break
            if mux.poll() is not None:
                log.error("mux stage exited %s", mux.returncode)
                rc = mux.returncode if mux.returncode else 1
                break
            time.sleep(0.2)
    finally:
        _stop = True
        for p in (enc, mux):
            if p and p.poll() is None:
                p.terminate()
                try:
                    p.wait(timeout=3)
                except Exception:
                    p.kill()
    return int(rc or 0)


def main() -> int:
    global _stop
    parser = argparse.ArgumentParser(description="NexBreak CC inject (H.264+A53)")
    parser.add_argument("--cue-sock", required=True)
    parser.add_argument(
        "--bitrate",
        default=os.environ.get("NEXBREAK_CC_INJECT_VBITRATE", "4000k"),
    )
    parser.add_argument(
        "--simple",
        action="store_true",
        default=os.environ.get("NEXBREAK_CC_INJECT_SIMPLE", "").lower() in ("1", "true", "yes"),
        help="single ffmpeg remux (no SEI) — most reliable",
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle)
    signal.signal(signal.SIGTERM, _handle)

    ffmpeg = shutil.which("ffmpeg") or os.environ.get("NEXBREAK_FFMPEG", "ffmpeg")
    threading.Thread(target=cue_listener, args=(args.cue_sock,), daemon=True).start()

    # Default to simple remux — dual-output pipe SEI is opt-in (NEXBREAK_CC_INJECT_SEI=1).
    want_sei = os.environ.get("NEXBREAK_CC_INJECT_SEI", "").lower() in ("1", "true", "yes")
    if args.simple or not want_sei:
        return run_simple(ffmpeg, args.bitrate)

    try:
        return run_with_sei(ffmpeg, args.bitrate)
    except Exception as exc:  # noqa: BLE001
        log.exception("SEI inject failed (%s) — falling back to simple", exc)
        return run_simple(ffmpeg, args.bitrate)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except BrokenPipeError:
        raise SystemExit(0)
