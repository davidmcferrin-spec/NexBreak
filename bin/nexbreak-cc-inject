#!/usr/bin/env python3
"""
nexbreak-cc-inject — MPEG-TS in → CEA-608 captioned MPEG-TS out.

Preferred path (Live Caption Encoder):
  stdin MPEG-TS → cc_injector (libav + libx264 a53cc=1) → stdout MPEG-TS
  Caption text arrives over UDP (--cc-udp), also bridged from the cue Unix socket
  that nexbreak-caption-worker already uses.

Fallback (no cc_injector binary):
  single ffmpeg H.264+AAC remux with NO captions (keeps the program path alive).

Install the injector:
  sudo bash scripts/install-ubuntu.sh cc-injector
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import select
import shutil
import signal
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Optional

log = logging.getLogger("nexbreak-cc-inject")
_stop = False


def _handle(signum, _frame):
    global _stop
    _stop = True


def find_cc_injector() -> Optional[str]:
    env = (os.environ.get("NEXBREAK_CC_INJECTOR") or "").strip()
    if env and os.path.isfile(env) and os.access(env, os.X_OK):
        return env
    which = shutil.which("cc_injector")
    if which:
        return which
    # Sibling of this script when installed under /opt/nexbreak/bin
    here = Path(__file__).resolve().parent
    for cand in (
        here / "cc_injector",
        Path("/usr/local/bin/cc_injector"),
        Path("/opt/nexbreak/bin/cc_injector"),
    ):
        if cand.is_file() and os.access(cand, os.X_OK):
            return str(cand)
    return None


def parse_cc_udp(spec: str) -> tuple[str, int]:
    spec = (spec or "").strip()
    if not spec:
        raise ValueError("empty --cc-udp")
    if ":" not in spec:
        raise ValueError(f"bad --cc-udp {spec!r} (want HOST:PORT)")
    host, _, port_s = spec.rpartition(":")
    host = host.strip() or "127.0.0.1"
    return host, int(port_s)


def send_udp_caption(sock: socket.socket, addr: tuple[str, int], text: str) -> None:
    """LCE accepts plain ASCII lines (≤32 chars recommended)."""
    line = (text or "").replace("\r", " ").replace("\n", " ").strip()
    if not line:
        return
    # Keep one readable line for RU2; LCE truncates aggressively.
    if len(line) > 32:
        line = line[:31].rstrip() + "…"
    # ASCII-ish for CEA-608
    raw = line.encode("ascii", errors="replace") + b"\n"
    try:
        sock.sendto(raw, addr)
    except OSError as exc:
        log.debug("cc-udp send failed: %s", exc)


def cue_to_udp_bridge(sock_path: str, udp_host: str, udp_port: int) -> None:
    """Forward caption-worker Unix-socket cues → LCE UDP text port."""
    Path(sock_path).parent.mkdir(parents=True, exist_ok=True)
    if os.path.exists(sock_path):
        try:
            os.unlink(sock_path)
        except OSError:
            pass
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(sock_path)
    srv.listen(4)
    os.chmod(sock_path, 0o660)
    srv.settimeout(1.0)
    udp = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    addr = (udp_host, int(udp_port))
    log.info("cue→udp bridge %s → %s:%s", sock_path, udp_host, udp_port)
    clients: list[socket.socket] = []
    bufmap: dict[socket.socket, bytes] = {}
    last_sent = ""
    try:
        while not _stop:
            rlist = [srv] + clients
            try:
                readable, _, _ = select.select(rlist, [], [], 0.5)
            except (ValueError, OSError):
                readable = []
            for s in readable:
                if s is srv:
                    try:
                        conn, _ = srv.accept()
                        conn.setblocking(False)
                        clients.append(conn)
                        bufmap[conn] = b""
                    except OSError:
                        pass
                    continue
                try:
                    chunk = s.recv(4096)
                except OSError:
                    chunk = b""
                if not chunk:
                    try:
                        s.close()
                    except OSError:
                        pass
                    clients = [c for c in clients if c is not s]
                    bufmap.pop(s, None)
                    continue
                bufmap[s] = bufmap.get(s, b"") + chunk
                while b"\n" in bufmap[s]:
                    line, bufmap[s] = bufmap[s].split(b"\n", 1)
                    try:
                        msg = json.loads(line.decode("utf-8", errors="replace"))
                    except json.JSONDecodeError:
                        continue
                    if msg.get("clear"):
                        text = ""
                    else:
                        text = str(msg.get("text") or "").strip()
                    if text and text != last_sent:
                        send_udp_caption(udp, addr, text)
                        last_sent = text
                    elif not text:
                        last_sent = ""
    finally:
        for c in clients:
            try:
                c.close()
            except OSError:
                pass
        try:
            srv.close()
        except OSError:
            pass
        try:
            udp.close()
        except OSError:
            pass
        try:
            os.unlink(sock_path)
        except OSError:
            pass


def run_simple(ffmpeg: str, bitrate: str) -> int:
    """Remux without captions — last-resort path-alive mode."""
    global _stop
    log.warning(
        "cc-inject simple remux (NO CEA-608) — install cc_injector: "
        "sudo bash scripts/install-ubuntu.sh cc-injector"
    )
    proc = subprocess.Popen(
        [
            ffmpeg,
            "-hide_banner",
            "-loglevel",
            "error",
            "-fflags",
            "+genpts+discardcorrupt",
            "-i",
            "pipe:0",
            "-map",
            "0:v:0",
            "-map",
            "0:a:0?",
            "-c:v",
            "libx264",
            "-preset",
            "ultrafast",
            "-tune",
            "zerolatency",
            "-profile:v",
            "main",
            "-pix_fmt",
            "yuv420p",
            "-b:v",
            bitrate,
            "-maxrate",
            bitrate,
            "-bufsize",
            "8M",
            "-g",
            "30",
            "-c:a",
            "aac",
            "-b:a",
            "128k",
            "-ac",
            "2",
            "-ar",
            "48000",
            "-f",
            "mpegts",
            "-mpegts_flags",
            "+resend_headers",
            "pipe:1",
        ],
        stdin=sys.stdin.buffer,
        stdout=sys.stdout.buffer,
        stderr=None,
    )
    try:
        while not _stop:
            code = proc.poll()
            if code is not None:
                return int(code or 0)
            time.sleep(0.2)
    finally:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=3)
            except Exception:
                proc.kill()
    return 0


def run_lce(
    injector: str,
    *,
    cue_sock: str,
    cc_udp: str,
    bitrate: str,
    bootstrap: bool,
    linger_ms: int,
) -> int:
    global _stop
    host, port = parse_cc_udp(cc_udp)
    bridge = threading.Thread(
        target=cue_to_udp_bridge,
        args=(cue_sock, host, port),
        daemon=True,
        name="cue-udp-bridge",
    )
    bridge.start()
    # Give the Unix socket a moment before caption-worker connects.
    time.sleep(0.15)

    argv = [
        injector,
        "pipe:0",
        "pipe:1",
        f"--cc-udp={host}:{port}",
        "--venc=libx264",
        f"--bitrate={bitrate}",
        f"--bootstrap={'1' if bootstrap else '0'}",
        f"--linger_ms={int(linger_ms)}",
    ]
    log.info("cc-inject LCE: %s", " ".join(argv))
    env = os.environ.copy()
    env["NEXBREAK_CC_INJECT_VBITRATE"] = bitrate

    proc = subprocess.Popen(
        argv,
        stdin=sys.stdin.buffer,
        stdout=sys.stdout.buffer,
        stderr=None,
        env=env,
    )
    try:
        while not _stop:
            code = proc.poll()
            if code is not None:
                log.error("cc_injector exited %s", code)
                return int(code or 0)
            time.sleep(0.2)
    finally:
        _stop = True
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=5)
            except Exception:
                proc.kill()
    return 0


def main() -> int:
    global _stop
    parser = argparse.ArgumentParser(
        description="NexBreak CC inject (Live Caption Encoder / cc_injector)"
    )
    parser.add_argument("--cue-sock", required=True)
    parser.add_argument(
        "--cc-udp",
        default=os.environ.get("NEXBREAK_CC_UDP", "127.0.0.1:22001"),
        help="HOST:PORT for LCE caption text UDP (default 127.0.0.1:22001)",
    )
    parser.add_argument(
        "--bitrate",
        default=os.environ.get("NEXBREAK_CC_INJECT_VBITRATE", "4000k"),
    )
    parser.add_argument(
        "--simple",
        action="store_true",
        default=os.environ.get("NEXBREAK_CC_INJECT_SIMPLE", "").lower()
        in ("1", "true", "yes"),
        help="force ffmpeg remux without captions",
    )
    parser.add_argument(
        "--bootstrap",
        action="store_true",
        default=os.environ.get("NEXBREAK_CC_BOOTSTRAP", "1").lower()
        not in ("0", "false", "no", "off"),
        help="LCE bootstrap 'CC ONLINE' (default on)",
    )
    parser.add_argument(
        "--linger-ms",
        type=int,
        default=int(os.environ.get("NEXBREAK_CC_LINGER_MS", "750")),
    )
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
    )
    signal.signal(signal.SIGINT, _handle)
    signal.signal(signal.SIGTERM, _handle)

    ffmpeg = shutil.which("ffmpeg") or os.environ.get("NEXBREAK_FFMPEG", "ffmpeg")
    if args.simple:
        return run_simple(ffmpeg, args.bitrate)

    injector = find_cc_injector()
    if not injector:
        return run_simple(ffmpeg, args.bitrate)

    try:
        return run_lce(
            injector,
            cue_sock=args.cue_sock,
            cc_udp=args.cc_udp,
            bitrate=args.bitrate,
            bootstrap=bool(args.bootstrap),
            linger_ms=int(args.linger_ms),
        )
    except Exception as exc:  # noqa: BLE001
        log.exception("LCE inject failed (%s) — falling back to simple", exc)
        return run_simple(ffmpeg, args.bitrate)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except BrokenPipeError:
        raise SystemExit(0)
